---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';

const services = [
  {
    title: "STAAD Pro Analysis",
    desc: "Advanced structural analysis using STAAD Pro for solar mounting structures and foundations",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  },
  {
    title: "Foundation Design",
    desc: "Pile, raft, and isolated footing designs for solar structures across varying soil conditions",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  {
    title: "PEB Structure Design",
    desc: "Pre-engineered building design for inverter rooms, control rooms, and equipment shelters",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>`,
  },
  {
    title: "MS/GI Structure",
    desc: "Mild steel and galvanized iron mounting structure design for rooftop and ground-mount systems",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"/>`,
  },
];
---

<Layout
  title="Solar Civil & Structural Engineering – Heaven Designs | STAAD Pro Analysis"
  description="Expert solar civil and structural engineering services. STAAD Pro structural analysis, foundation design, PEB structures, and civil engineering for solar installations."
  canonical="https://heavendesigns.in/solar-civil-and-structural-engineering/"
>
  <Navbar />
  <main>
    <PageHero
      title="Solar Civil & Structural Engineering"
      subtitle="Expert structural analysis and civil engineering for all solar project types."
      breadcrumbs={[
        { label: "Our Services", href: "/our-services/" },
        { label: "Solar Civil & Structural Engineering" },
      ]}
    />

    <!-- Section 1: Intro -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-sm font-semibold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Poppins',sans-serif">
              — CIVIL & STRUCTURAL
            </p>
            <h2 class="text-3xl sm:text-4xl font-black text-[#0f172a] mb-6" style="font-family:'Montserrat',sans-serif">
              Solar Civil & Structural Engineering
            </h2>
            <p class="text-gray-600 leading-relaxed mb-8" style="font-family:'Poppins',sans-serif">
              Heaven Designs provides expert civil and structural engineering services for solar installations. Using STAAD Pro and industry-standard methodologies, our engineers deliver safe, cost-optimized structural designs for all project types.
            </p>
            <a
              href="/contact-us/"
              class="inline-block px-8 py-3 bg-[#FFA91F] text-white font-semibold rounded hover:bg-[#e8970d] transition-colors"
              style="font-family:'Poppins',sans-serif"
            >
              Get Engineering Support
            </a>
          </div>
          <div>
            <img
              src="/images/services/service-4.webp"
              alt="Solar Civil and Structural Engineering"
              class="w-full rounded-xl shadow-lg object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Engineering Services -->
    <section class="py-16 bg-[#f9fafb]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="text-3xl sm:text-4xl font-black text-[#0f172a] mb-12 text-center" style="font-family:'Montserrat',sans-serif">
          Engineering Services
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {services.map((s) => (
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center hover:shadow-md transition-shadow">
              <div class="w-12 h-12 flex items-center justify-center rounded-full bg-[#149C68]/10 mx-auto mb-4">
                <svg class="w-6 h-6 text-[#149C68]" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={s.icon} />
              </div>
              <h3 class="font-bold text-[#0f172a] mb-2" style="font-family:'Montserrat',sans-serif">{s.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed" style="font-family:'Poppins',sans-serif">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>
