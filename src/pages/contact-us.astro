---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "name": "Contact Heaven Designs",
  "url": "https://heavendesigns.in/contact-us/"
};
---

<Layout
  title="Contact Us – Heaven Designs | Get a Solar Design Quote"
  description="Contact Heaven Designs for solar design, engineering & consultancy services. Reach us in Surat or Ahmedabad, Gujarat. Call +91 90811 00297."
  canonical="https://heavendesigns.in/contact-us/"
  schema={schema}
>
  <Navbar />
  <main>
    <PageHero
      title="Contact Us"
      subtitle="Get in touch with our team for a quick solar design quote or consultation."
      breadcrumbs={[{ label: 'Contact Us' }]}
    />

    <!-- 3 info cards in a row -->
    <section class="py-12 px-4 sm:px-6 bg-white">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-10 text-center" style="font-family:'Montserrat',sans-serif">
          Contact Information
        </h2>
        <div class="grid sm:grid-cols-3 gap-6 mb-12">
          <!-- Address -->
          <div class="bg-white rounded-2xl shadow-md border border-gray-100 p-8 flex flex-col items-center text-center hover:border-[#149C68] transition-colors">
            <div class="w-16 h-16 rounded-full bg-[#149C68]/10 flex items-center justify-center mb-5">
              <img src="/images/contact/address.webp" alt="Address" class="w-9 h-9 object-contain" loading="lazy" />
            </div>
            <h3 class="font-bold text-gray-900 text-lg mb-3" style="font-family:'Montserrat',sans-serif">Address</h3>
            <p class="text-gray-600 text-sm leading-relaxed" style="font-family:'Poppins',sans-serif">
              204 Anupam Square, SAT Swaminarayan Temple Rd,<br />Mota Varachha, Surat, Gujarat 394101
            </p>
          </div>

          <!-- Phone -->
          <div class="bg-white rounded-2xl shadow-md border border-gray-100 p-8 flex flex-col items-center text-center hover:border-[#149C68] transition-colors">
            <div class="w-16 h-16 rounded-full bg-[#149C68]/10 flex items-center justify-center mb-5">
              <img src="/images/contact/phone.webp" alt="Phone" class="w-9 h-9 object-contain" loading="lazy" />
            </div>
            <h3 class="font-bold text-gray-900 text-lg mb-3" style="font-family:'Montserrat',sans-serif">Phone Number</h3>
            <a href="tel:+919081100297" class="text-[#149C68] font-semibold text-sm hover:underline block mb-1" style="font-family:'Poppins',sans-serif">
              +91 90811 00297
            </a>
            <p class="text-gray-600 text-sm" style="font-family:'Poppins',sans-serif">+91 84692 00148</p>
          </div>

          <!-- Email -->
          <div class="bg-white rounded-2xl shadow-md border border-gray-100 p-8 flex flex-col items-center text-center hover:border-[#149C68] transition-colors">
            <div class="w-16 h-16 rounded-full bg-[#149C68]/10 flex items-center justify-center mb-5">
              <img src="/images/contact/email.webp" alt="Email" class="w-9 h-9 object-contain" loading="lazy" />
            </div>
            <h3 class="font-bold text-gray-900 text-lg mb-3" style="font-family:'Montserrat',sans-serif">Email</h3>
            <a href="mailto:service@heavendesigns.in" class="text-[#149C68] font-semibold text-sm hover:underline block mb-1" style="font-family:'Poppins',sans-serif">
              service@heavendesigns.in
            </a>
            <a href="mailto:info@heavendesigns.in" class="text-gray-600 text-sm hover:text-[#149C68] transition-colors" style="font-family:'Poppins',sans-serif">
              info@heavendesigns.in
            </a>
          </div>
        </div>

        <!-- Map + Form -->
        <div class="grid lg:grid-cols-2 gap-10 items-start">

          <!-- Map -->
          <div>
            <div class="rounded-2xl overflow-hidden shadow-md h-[420px]">
              <iframe
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3719.4562!2d72.9088!3d21.2238!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3be04e36a0f1c0a7%3A0xa0a7b5f6a1e5d0f!2sMota%20Varachha%2C%20Surat%2C%20Gujarat!5e0!3m2!1sen!2sin!4v1700000000000"
                width="100%"
                height="100%"
                style="border:0;"
                allowfullscreen=""
                loading="lazy"
                referrerpolicy="no-referrer-when-downgrade"
                title="Heaven Designs Surat Office Location"
              ></iframe>
            </div>
          </div>

          <!-- Form -->
          <div>
            <h2 class="text-2xl sm:text-3xl font-black text-gray-900 mb-2 leading-tight" style="font-family:'Montserrat',sans-serif">
              How can we help?
            </h2>
            <p class="text-gray-600 mb-7 text-sm" style="font-family:'Poppins',sans-serif">
              Fill out the form and our team will reply within 4 hours.
            </p>
            <form action="#" method="POST" class="space-y-4">
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5" style="font-family:'Montserrat',sans-serif">
                  Name <span class="text-red-500">*</span>
                </label>
                <input type="text" name="name" placeholder="Your Name" required
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#149C68]" style="font-family:'Poppins',sans-serif" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5" style="font-family:'Montserrat',sans-serif">
                  Email Id <span class="text-red-500">*</span>
                </label>
                <input type="email" name="email" placeholder="your@email.com" required
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#149C68]" style="font-family:'Poppins',sans-serif" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5" style="font-family:'Montserrat',sans-serif">Company Name</label>
                <input type="text" name="company" placeholder="Your Company Name"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#149C68]" style="font-family:'Poppins',sans-serif" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5" style="font-family:'Montserrat',sans-serif">Whatsapp</label>
                <input type="tel" name="whatsapp" placeholder="+91 XXXXX XXXXX"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#149C68]" style="font-family:'Poppins',sans-serif" />
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5" style="font-family:'Montserrat',sans-serif">Service Required</label>
                <select name="service"
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#149C68] bg-white text-gray-600" style="font-family:'Poppins',sans-serif">
                  <option value="" disabled selected>Solar 3D Pre-Design</option>
                  <option value="solar-3d-pre-design">Solar 3D Pre-Design</option>
                  <option value="solar-post-design">Solar Post Design</option>
                  <option value="ground-mount-design">Ground Mount Design</option>
                  <option value="rooftop-engineering">Rooftop Engineering</option>
                  <option value="project-management">MW Scale Project Management</option>
                  <option value="permit-design">Solar Permit Design</option>
                  <option value="civil-structural">Civil & Structural Engineering</option>
                  <option value="site-survey">Site Survey & Feasibility</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-semibold text-gray-700 mb-1.5" style="font-family:'Montserrat',sans-serif">Message</label>
                <textarea name="message" rows="4" placeholder="Tell us about your project..."
                  class="w-full border border-gray-200 rounded-lg px-4 py-3 text-sm focus:outline-none focus:border-[#149C68] resize-none" style="font-family:'Poppins',sans-serif"></textarea>
              </div>
              <button type="submit"
                class="w-full bg-[#149C68] hover:bg-[#0f7a50] text-white font-bold py-3.5 rounded-lg transition-colors text-sm tracking-wide"
                style="font-family:'Montserrat',sans-serif">
                Submit
              </button>
            </form>
          </div>

        </div>
      </div>
    </section>

  </main>
  <Footer />
</Layout>
