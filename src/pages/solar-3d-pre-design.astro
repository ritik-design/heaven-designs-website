---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Solar 3D Pre-Design",
  "provider": { "@type": "Organization", "name": "Heaven Designs Private Limited" },
  "description": "Solar pre-design using SketchUp, BricsCAD with PVsyst energy forecasts and shading analysis",
  "url": "https://heavendesigns.in/solar-3d-pre-design/",
  "areaServed": "Worldwide"
};

const keyPoints = [
  "Initial phase of solar project planning",
  "Uses software like SketchUp and AutoCAD",
  "Creates a 3D model for visualizing the solar installation",
  "Involves data collection from Google Maps and client-provided measurements",
  "Includes reports like PVsyst energy forecasts, shading analysis, and ROI projections",
];

const benefits = [
  {
    title: "Accurate Project Planning",
    desc: "Meticulous planning ensures accurate resource allocation and timeline management",
  },
  {
    title: "Enhanced Client Trust",
    desc: "Professional 3D visualizations build confidence and help close sales faster",
  },
  {
    title: "Risk Mitigation",
    desc: "Identify potential shading and structural issues before installation begins",
  },
  {
    title: "Informed Decision-Making",
    desc: "Data-driven insights from PVsyst reports support better investment decisions",
  },
];

const preDesignTypes = [
  {
    title: "Residential Rooftop",
    desc: "Optimized layouts for homes, with shading analysis and panel placement",
  },
  {
    title: "Commercial & Industrial",
    desc: "Large-scale rooftop designs with load calculations and CEIG compliance",
  },
  {
    title: "Ground-Mounted",
    desc: "Utility scale designs with terrain analysis and optimal row spacing",
  },
];

const galleryImages = [
  { src: "/images/services/s1/img1.webp", alt: "Solar Pre-Design Sample 1" },
  { src: "/images/services/s1/img2.webp", alt: "Solar Pre-Design Sample 2" },
  { src: "/images/services/s1/img3.webp", alt: "Solar Pre-Design Sample 3" },
  { src: "/images/services/s1/img4.webp", alt: "Solar Pre-Design Sample 4" },
];
---

<Layout
  title="Solar 3D Pre-Design Services – Heaven Designs | Solar Layout & Shading Analysis"
  description="Professional Solar 3D Pre-Design services using SketchUp & BricsCAD. Accurate shading analysis, PVsyst energy forecasts, and ROI projections for EPC companies worldwide."
  canonical="https://heavendesigns.in/solar-3d-pre-design/"
  schema={schema}
>
  <Navbar />
  <main>
    <PageHero
      title="Solar 3D Pre-Design"
      subtitle="Accurate 3D solar layouts with shading analysis, PVsyst reports, and ROI projections for EPC companies worldwide."
      breadcrumbs={[
        { label: "Our Services", href: "/our-services/" },
        { label: "Solar 3D Pre-Design" },
      ]}
    />

    <!-- Section 1: Service Overview -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Left: Text -->
          <div>
            <p class="text-sm font-semibold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Poppins',sans-serif">
              — SOLAR DESIGN
            </p>
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-[#0f172a] mb-6" style="font-family:'Montserrat',sans-serif">
              What is Solar Pre-Design?
            </h2>
            <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-5" style="font-family:'Poppins',sans-serif">
              Solar Pre-Design, also known as Solar Preliminary Design, is the first phase in planning a solar project. It involves creating initial drawings and designs using software like SketchUp and BricsCAD. This process gathers data from sources such as Google Maps and site measurements provided by the client to develop a detailed 3D model.
            </p>
            <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-8" style="font-family:'Poppins',sans-serif">
              This model helps visualize the solar installation, offering insights into shading, energy production, and financial returns. It is essential for EPC companies to present accurate proposals to their clients.
            </p>
            <a
              href="/contact-us/"
              class="inline-block px-8 py-3 bg-[#FFA91F] text-white font-semibold rounded hover:bg-[#e8970d] transition-colors"
              style="font-family:'Poppins',sans-serif"
            >
              Get a Free Quote
            </a>
          </div>
          <!-- Right: Image -->
          <div>
            <img
              src="/images/services/s1/hero.webp"
              alt="Solar 3D Pre-Design by Heaven Designs"
              class="w-full rounded-xl shadow-lg object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Key Points -->
    <section class="py-16 bg-[#f9fafb]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-10">
          <p class="text-sm font-semibold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Poppins',sans-serif">
            — SERVICE SCOPE
          </p>
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-[#0f172a]" style="font-family:'Montserrat',sans-serif">
            Key Points
          </h2>
        </div>
        <ul class="max-w-3xl mx-auto space-y-4">
          {keyPoints.map((point) => (
            <li class="flex items-start gap-4 bg-white rounded-lg p-5 shadow-sm border border-gray-100">
              <!-- Green checkmark icon -->
              <span class="shrink-0 mt-0.5 w-6 h-6 flex items-center justify-center rounded-full bg-[#149C68]">
                <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                </svg>
              </span>
              <span class="text-gray-700 leading-relaxed" style="font-family:'Poppins',sans-serif">{point}</span>
            </li>
          ))}
        </ul>
      </div>
    </section>

    <!-- Section 3: Why Pre-Design is Crucial -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-[#0f172a] mb-12 text-center" style="font-family:'Montserrat',sans-serif">
          Why Solar Pre-Design is Crucial
        </h2>
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <!-- Left: Benefit Cards -->
          <div class="space-y-5">
            {benefits.map((benefit) => (
              <div class="flex items-start gap-4 p-5 rounded-xl border border-gray-100 shadow-sm hover:shadow-md transition-shadow">
                <span class="shrink-0 mt-0.5 w-8 h-8 flex items-center justify-center rounded-full bg-[#149C68]/10">
                  <svg class="w-4 h-4 text-[#149C68]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
                  </svg>
                </span>
                <div>
                  <h3 class="font-bold text-[#0f172a] mb-1" style="font-family:'Montserrat',sans-serif">
                    {benefit.title}
                  </h3>
                  <p class="text-gray-600 text-sm sm:text-base leading-relaxed" style="font-family:'Poppins',sans-serif">
                    {benefit.desc}
                  </p>
                </div>
              </div>
            ))}
          </div>
          <!-- Right: Image -->
          <div>
            <img
              src="/images/services/s1/img1.webp"
              alt="Solar Pre-Design Benefits"
              class="w-full rounded-xl shadow-lg object-cover"
              loading="lazy"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 4: Types of Pre-Designs -->
    <section class="py-16 bg-[#149C68]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-white mb-12" style="font-family:'Montserrat',sans-serif">
          Types of Solar Pre-Designs
        </h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-5 sm:gap-6">
          {preDesignTypes.map((type) => (
            <div class="bg-white rounded-xl p-6 shadow-md text-left">
              <h3 class="text-lg font-bold text-[#0f172a] mb-3" style="font-family:'Montserrat',sans-serif">
                {type.title}
              </h3>
              <p class="text-gray-600 text-sm sm:text-base leading-relaxed" style="font-family:'Poppins',sans-serif">
                {type.desc}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 5: Gallery -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-[#0f172a] mb-10 text-center" style="font-family:'Montserrat',sans-serif">
          Sample Solar Pre-Designs
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {galleryImages.map((img) => (
            <div class="overflow-hidden rounded-lg shadow-md">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-48 object-cover hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>
