---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "JobPosting",
  "hiringOrganization": {
    "@type": "Organization",
    "name": "Heaven Designs Private Limited"
  },
  "jobLocation": {
    "@type": "Place",
    "address": {
      "@type": "PostalAddress",
      "addressLocality": "Surat",
      "addressRegion": "Gujarat",
      "addressCountry": "IN"
    }
  },
  "title": "Solar Design Engineer",
  "description": "Join Heaven Designs as a Solar Design Engineer. Work on cutting-edge solar projects for EPC companies globally.",
  "employmentType": "FULL_TIME"
};

const benefits = [
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>`,
    title: "Growth Opportunities",
    desc: "Fast-track your career in the booming solar energy sector"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
    title: "Expert Mentorship",
    desc: "Learn from 50+ experienced engineers and industry leaders"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
    title: "Flexible Environment",
    desc: "We value work-life balance and a collaborative culture"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2h-2"/></svg>`,
    title: "Cutting-Edge Tools",
    desc: "Work with industry-leading software like BricsCAD, PVsyst & SketchUp"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064"/></svg>`,
    title: "Global Projects",
    desc: "Design solar installations for clients in 15+ countries"
  },
  {
    icon: `<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/></svg>`,
    title: "Team Culture",
    desc: "Festivals, trips, and activities that make work feel like family"
  }
];

const jobs = [
  {
    title: "Solar Design Engineer",
    location: "Surat, Gujarat",
    type: "Full Time",
    desc: "Design solar PV systems using BricsCAD, SketchUp, and PVsyst for residential, commercial, and utility-scale projects."
  },
  {
    title: "Structural Engineer (Solar)",
    location: "Surat, Gujarat",
    type: "Full Time",
    desc: "Perform structural analysis using STAAD Pro for solar mounting structures. Design PEB and MS/GI structures."
  },
  {
    title: "Project Coordinator",
    location: "Surat, Gujarat",
    type: "Full Time",
    desc: "Coordinate with clients, manage project timelines, and ensure on-time delivery of design deliverables."
  },
  {
    title: "AutoCAD Draftsman",
    location: "Surat, Gujarat",
    type: "Full Time",
    desc: "Create detailed 2D drawings for solar installations including single-line diagrams and site plans."
  }
];
---

<Layout
  title="Join Our Team – Heaven Designs | Solar Engineering Careers in Surat"
  description="Build your career in solar energy with Heaven Designs. We're hiring solar designers, engineers, and consultants. Join a growing team in Surat, Gujarat."
  canonical="https://heavendesigns.in/join-our-team/"
  schema={schema}
>
  <Navbar />
  <main>
    <PageHero
      title="Join Our Team"
      subtitle="Build your career in solar energy with a passionate team making a global impact."
      breadcrumbs={[{ label: 'Join Our Team' }]}
    />

    <!-- Section 1: Why Join Us -->
    <section class="py-16 px-4 sm:px-6 bg-white">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 items-center">

          <!-- Left: Text + Benefits -->
          <div>
            <p class="text-sm font-bold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Montserrat',sans-serif">
              — CAREERS
            </p>
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-gray-900 mb-5 leading-tight" style="font-family:'Montserrat',sans-serif">
              Why You Should Join Us?
            </h2>
            <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-10" style="font-family:'Poppins',sans-serif">
              At Heaven Designs, we believe that great people create great products. Join a team of passionate engineers working on cutting-edge solar projects that impact the world.
            </p>

            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
              {benefits.map((benefit) => (
                <div class="group bg-gray-50 hover:bg-[#149C68]/5 border border-gray-100 hover:border-[#149C68]/20 rounded-xl p-5 transition-all duration-300">
                  <div class="w-12 h-12 rounded-xl bg-[#149C68]/10 text-[#149C68] flex items-center justify-center mb-4" set:html={benefit.icon} />
                  <h3 class="font-bold text-gray-900 text-lg mb-1.5" style="font-family:'Montserrat',sans-serif">
                    {benefit.title}
                  </h3>
                  <p class="text-gray-500 text-xs leading-relaxed" style="font-family:'Poppins',sans-serif">
                    {benefit.desc}
                  </p>
                </div>
              ))}
            </div>
          </div>

          <!-- Right: Image -->
          <div class="relative">
            <img
              src="/images/about/banner.webp"
              alt="Heaven Designs team"
              class="w-full rounded-2xl object-cover shadow-xl"
              loading="lazy"
            />
            <div class="absolute -bottom-4 -right-4 w-24 h-24 bg-[#FFA91F] rounded-2xl opacity-20 -z-10"></div>
            <div class="absolute -top-4 -left-4 w-16 h-16 bg-[#149C68] rounded-full opacity-20 -z-10"></div>
          </div>

        </div>
      </div>
    </section>

    <!-- Section 2: Open Positions -->
    <section class="py-16 px-4 sm:px-6 bg-gray-50">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-12">
          <p class="text-sm font-bold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Montserrat',sans-serif">
            — OPEN POSITIONS
          </p>
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-gray-900 mb-4 leading-tight" style="font-family:'Montserrat',sans-serif">
            Apply Now For Success
          </h2>
          <p class="text-gray-600 max-w-xl mx-auto" style="font-family:'Poppins',sans-serif">
            We are always looking for talented individuals to join our growing team.
          </p>
        </div>

        <div class="grid sm:grid-cols-2 gap-6">
          {jobs.map((job) => (
            <div class="bg-white rounded-xl shadow-sm border-l-4 border-[#149C68] p-6 flex flex-col gap-4">
              <div class="flex items-start justify-between gap-4">
                <h3 class="font-black text-gray-900 text-lg leading-tight" style="font-family:'Montserrat',sans-serif">
                  {job.title}
                </h3>
                <span class="shrink-0 text-xs font-bold bg-[#149C68]/10 text-[#149C68] px-3 py-1 rounded-full" style="font-family:'Montserrat',sans-serif">
                  {job.type}
                </span>
              </div>
              <div class="flex items-center gap-2 text-sm text-gray-500" style="font-family:'Poppins',sans-serif">
                <svg class="w-4 h-4 text-[#149C68] shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                {job.location}
              </div>
              <p class="text-gray-600 text-sm sm:text-base leading-relaxed flex-1" style="font-family:'Poppins',sans-serif">
                {job.desc}
              </p>
              <div>
                <a
                  href="/contact-us/"
                  class="text-[#149C68] font-bold text-sm hover:underline transition-colors"
                  style="font-family:'Montserrat',sans-serif"
                >
                  Apply Now →
                </a>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- Section 3: Application Form -->
    <section class="py-16 px-4 sm:px-6 bg-white">
      <div class="max-w-7xl mx-auto">
        <div class="text-center mb-10">
          <p class="text-sm font-bold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Montserrat',sans-serif">
            — APPLY NOW
          </p>
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-gray-900 mb-4 leading-tight" style="font-family:'Montserrat',sans-serif">
            Submit Your Application
          </h2>
          <p class="text-gray-600" style="font-family:'Poppins',sans-serif">
            Send us your resume and we'll reach out if there's a good fit.
          </p>
        </div>

        <div class="bg-white shadow rounded-xl p-8 max-w-2xl mx-auto">
          <form action="#" method="POST" class="space-y-5">

            <!-- Name -->
            <div>
              <label for="app-name" class="block text-sm font-semibold text-gray-700 mb-1.5" style="font-family:'Montserrat',sans-serif">
                Full Name <span class="text-red-500">*</span>
              </label>
              <input
                type="text"
                id="app-name"
                name="name"
                placeholder="Your full name"
                required
                class="w-full border border-gray-200 rounded-lg px-4 py-3 focus:outline-none focus:border-[#149C68] text-sm"
                style="font-family:'Poppins',sans-serif"
              />
            </div>

            <!-- Email -->
            <div>
              <label for="app-email" class="block text-sm font-semibold text-gray-700 mb-1.5" style="font-family:'Montserrat',sans-serif">
                Email Address <span class="text-red-500">*</span>
              </label>
              <input
                type="email"
                id="app-email"
                name="email"
                placeholder="your@email.com"
                required
                class="w-full border border-gray-200 rounded-lg px-4 py-3 focus:outline-none focus:border-[#149C68] text-sm"
                style="font-family:'Poppins',sans-serif"
              />
            </div>

            <!-- Phone -->
            <div>
              <label for="app-phone" class="block text-sm font-semibold text-gray-700 mb-1.5" style="font-family:'Montserrat',sans-serif">
                Phone Number
              </label>
              <input
                type="tel"
                id="app-phone"
                name="phone"
                placeholder="+91 XXXXX XXXXX"
                class="w-full border border-gray-200 rounded-lg px-4 py-3 focus:outline-none focus:border-[#149C68] text-sm"
                style="font-family:'Poppins',sans-serif"
              />
            </div>

            <!-- Position -->
            <div>
              <label for="app-position" class="block text-sm font-semibold text-gray-700 mb-1.5" style="font-family:'Montserrat',sans-serif">
                Position Applied For <span class="text-red-500">*</span>
              </label>
              <select
                id="app-position"
                name="position"
                required
                class="w-full border border-gray-200 rounded-lg px-4 py-3 focus:outline-none focus:border-[#149C68] text-sm text-gray-600 bg-white"
                style="font-family:'Poppins',sans-serif"
              >
                <option value="" disabled selected>Select a position</option>
                <option value="solar-design-engineer">Solar Design Engineer</option>
                <option value="structural-engineer">Structural Engineer (Solar)</option>
                <option value="project-coordinator">Project Coordinator</option>
                <option value="autocad-draftsman">AutoCAD Draftsman</option>
                <option value="other">Other</option>
              </select>
            </div>

            <!-- Experience -->
            <div>
              <label for="app-experience" class="block text-sm font-semibold text-gray-700 mb-1.5" style="font-family:'Montserrat',sans-serif">
                Years of Experience
              </label>
              <select
                id="app-experience"
                name="experience"
                class="w-full border border-gray-200 rounded-lg px-4 py-3 focus:outline-none focus:border-[#149C68] text-sm text-gray-600 bg-white"
                style="font-family:'Poppins',sans-serif"
              >
                <option value="" disabled selected>Select experience level</option>
                <option value="0-1">0–1 year</option>
                <option value="1-3">1–3 years</option>
                <option value="3-5">3–5 years</option>
                <option value="5+">5+ years</option>
              </select>
            </div>

            <!-- Cover Letter -->
            <div>
              <label for="app-message" class="block text-sm font-semibold text-gray-700 mb-1.5" style="font-family:'Montserrat',sans-serif">
                Message / Cover Letter
              </label>
              <textarea
                id="app-message"
                name="message"
                rows="5"
                placeholder="Tell us about yourself and why you'd like to join Heaven Designs..."
                class="w-full border border-gray-200 rounded-lg px-4 py-3 focus:outline-none focus:border-[#149C68] text-sm resize-none"
                style="font-family:'Poppins',sans-serif"
              ></textarea>
            </div>

            <!-- Submit -->
            <button
              type="submit"
              class="w-full bg-[#FFA91F] hover:bg-[#e8961a] text-white font-bold py-3.5 px-8 rounded-lg transition-colors duration-200 text-sm tracking-wide"
              style="font-family:'Montserrat',sans-serif"
            >
              Submit Application
            </button>

          </form>
        </div>

      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>
