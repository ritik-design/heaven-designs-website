---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';

const scopeItems = [
  {
    title: "Solar Layout Design",
    desc: "Detailed panel placement, string configuration, and rooftop layout drawings",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/>`,
  },
  {
    title: "Electrical (CEIG) Drawings",
    desc: "Complete single-line, three-line, and schematic electrical drawings for CEIG approval",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
  {
    title: "STAAD PRO Reports",
    desc: "Structural analysis reports for mounting structures using STAAD Pro software",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  },
  {
    title: "Permit Documentation",
    desc: "Complete documentation packages for statutory approvals and project execution",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>`,
  },
];

const projectTypes = [
  {
    title: "Industrial Rooftop",
    desc: "Large-scale industrial rooftop solar designs for factories, warehouses, and manufacturing facilities",
  },
  {
    title: "Ground Mount Solar",
    desc: "MW-scale ground-mounted solar farm engineering with complete documentation packages",
  },
  {
    title: "Commercial Rooftop",
    desc: "Commercial building rooftop solar designs with structural assessment and electrical engineering",
  },
];
---

<Layout
  title="Solar Rooftop Detailed Engineering Design – Heaven Designs"
  description="Complete detailed engineering design for industrial and commercial rooftop solar projects. CEIG drawings, load calculations, structural analysis, and permit documentation."
  canonical="https://heavendesigns.in/solar-rooftop-detailed-engineering-design/"
>
  <Navbar />
  <main>
    <PageHero
      title="MW Scale Detailed Engineering Design"
      subtitle="Complete engineering design packages for industrial rooftop and ground-mounted MW-scale solar projects."
      breadcrumbs={[
        { label: "Our Services", href: "/our-services/" },
        { label: "Solar Rooftop Detailed Engineering Design" },
      ]}
    />

    <!-- Section 1: Intro -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-sm font-semibold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Poppins',sans-serif">
              — ROOFTOP ENGINEERING
            </p>
            <h2 class="text-3xl sm:text-4xl font-black text-[#0f172a] mb-6" style="font-family:'Montserrat',sans-serif">
              MW Scale Detailed Engineering Design
            </h2>
            <p class="text-gray-600 leading-relaxed text-lg mb-8" style="font-family:'Poppins',sans-serif">
              Heaven Designs delivers comprehensive detailed engineering design packages for industrial rooftop and ground-mounted solar projects. Our MW-scale expertise ensures every design meets engineering standards and EPC requirements.
            </p>
            <a
              href="/contact-us/"
              class="inline-block px-8 py-3 bg-[#FFA91F] text-white font-semibold rounded hover:bg-[#e8970d] transition-colors"
              style="font-family:'Poppins',sans-serif"
            >
              Get Engineering Design
            </a>
          </div>
          <div>
            <img
              src="/images/services/service-2.webp"
              alt="MW Scale Detailed Engineering Design"
              class="w-full rounded-xl shadow-lg object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Scope -->
    <section class="py-16 bg-[#f9fafb]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="text-3xl sm:text-4xl font-black text-[#0f172a] mb-12 text-center" style="font-family:'Montserrat',sans-serif">
          What's Included
        </h2>
        <div class="grid sm:grid-cols-2 gap-6">
          {scopeItems.map((item) => (
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex items-start gap-4 hover:shadow-md transition-shadow">
              <div class="shrink-0 w-11 h-11 flex items-center justify-center rounded-full bg-[#149C68]/10">
                <svg class="w-5 h-5 text-[#149C68]" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={item.icon} />
              </div>
              <div>
                <h3 class="font-bold text-[#0f172a] mb-1" style="font-family:'Montserrat',sans-serif">{item.title}</h3>
                <p class="text-gray-600 text-lg leading-relaxed" style="font-family:'Poppins',sans-serif">{item.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 3: Project Types -->
    <section class="py-16 bg-[#149C68]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 text-center">
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-12" style="font-family:'Montserrat',sans-serif">
          Project Types We Handle
        </h2>
        <div class="grid sm:grid-cols-3 gap-6">
          {projectTypes.map((type) => (
            <div class="bg-white rounded-xl p-6 shadow-md text-left">
              <h3 class="text-lg font-bold text-[#0f172a] mb-3" style="font-family:'Montserrat',sans-serif">
                {type.title}
              </h3>
              <p class="text-gray-600 text-lg leading-relaxed" style="font-family:'Poppins',sans-serif">
                {type.desc}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>
