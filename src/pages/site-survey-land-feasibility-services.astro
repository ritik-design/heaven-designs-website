---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Site Survey & Land Feasibility Services",
  "provider": { "@type": "Organization", "name": "Heaven Designs Private Limited" },
  "areaServed": "India",
  "url": "https://heavendesigns.in/site-survey-land-feasibility-services/"
};

const galleryImages = [
  { src: "/images/services/s4/hero.webp", alt: "Site Survey Services" },
  { src: "/images/services/s4/img1.webp", alt: "Contour Mapping Survey" },
  { src: "/images/services/s4/img2.webp", alt: "Geo-Technical Survey" },
];
---

<Layout
  title="Site Survey & Land Feasibility Services – Heaven Designs | India-Wide"
  description="Professional site survey and land feasibility services across India. Contour mapping, soil testing, geo-technical reports, and Earth Resistivity Reports."
  canonical="https://heavendesigns.in/site-survey-land-feasibility-services/"
  schema={schema}
>
  <Navbar />
  <main>
    <PageHero
      title="Site Survey & Land Feasibility Services"
      subtitle="Professional site survey and land feasibility services across India using advanced equipment."
      breadcrumbs={[
        { label: "Our Services", href: "/our-services/" },
        { label: "Site Survey & Land Feasibility Services" },
      ]}
    />

    <!-- Section 1: Intro -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-sm font-semibold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Poppins',sans-serif">
              — SURVEY SERVICES
            </p>
            <h2 class="text-3xl sm:text-4xl font-black text-[#0f172a] mb-6" style="font-family:'Montserrat',sans-serif">
              Site Survey & Land Feasibility Services
            </h2>
            <p class="text-gray-600 leading-relaxed text-lg mb-8" style="font-family:'Poppins',sans-serif">
              Heaven Designs provides comprehensive site survey and land feasibility services across India. Our expert surveyors use advanced equipment to deliver accurate topographic data, soil analysis, and feasibility reports essential for solar project planning.
            </p>
            <a
              href="/contact-us/"
              class="inline-block px-8 py-3 bg-[#FFA91F] text-white font-semibold rounded hover:bg-[#e8970d] transition-colors"
              style="font-family:'Poppins',sans-serif"
            >
              Request a Survey
            </a>
          </div>
          <div>
            <img
              src="/images/services/s4/hero.webp"
              alt="Site Survey & Land Feasibility Services"
              class="w-full rounded-xl shadow-lg object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Services -->
    <section class="py-16 bg-[#f9fafb]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <p class="text-sm font-semibold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Poppins',sans-serif">
            — WHAT WE COVER
          </p>
          <h2 class="text-3xl sm:text-4xl font-black text-[#0f172a]" style="font-family:'Montserrat',sans-serif">
            Key Points
          </h2>
        </div>
        <div class="grid lg:grid-cols-2 gap-8">
          <!-- Card 1 -->
          <div class="bg-white rounded-xl shadow-md overflow-hidden">
            <img
              src="/images/services/s4/img1.webp"
              alt="Contour Mapping Survey"
              class="w-full h-52 object-cover"
              loading="lazy"
            />
            <div class="p-6">
              <h3 class="text-xl font-bold text-[#0f172a] mb-3" style="font-family:'Montserrat',sans-serif">
                Contour Mapping Survey — Across India
              </h3>
              <p class="text-gray-600 leading-relaxed text-lg" style="font-family:'Poppins',sans-serif">
                Professional topographic surveys using advanced GPS and total station equipment. Generates accurate contour maps essential for solar farm layout design and grading plans.
              </p>
            </div>
          </div>
          <!-- Card 2 -->
          <div class="bg-white rounded-xl shadow-md overflow-hidden">
            <img
              src="/images/services/s4/img2.webp"
              alt="Soil Test and Geo-Technical Reports"
              class="w-full h-52 object-cover"
              loading="lazy"
            />
            <div class="p-6">
              <h3 class="text-xl font-bold text-[#0f172a] mb-3" style="font-family:'Montserrat',sans-serif">
                Soil Test, Earth Resistivity & Geo-Technical Reports
              </h3>
              <p class="text-gray-600 leading-relaxed text-lg" style="font-family:'Poppins',sans-serif">
                Comprehensive soil testing, earth resistivity measurements, and geo-technical reports to support foundation design for solar structures.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3: Gallery -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="text-3xl sm:text-4xl font-black text-[#0f172a] mb-10 text-center" style="font-family:'Montserrat',sans-serif">
          Our Gallery
        </h2>
        <div class="grid sm:grid-cols-3 gap-6">
          {galleryImages.map((img) => (
            <div class="overflow-hidden rounded-xl shadow-md">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-56 object-cover hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>
