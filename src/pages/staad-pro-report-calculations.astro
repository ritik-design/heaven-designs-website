---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "STAAD Pro Report & Calculations",
  "provider": { "@type": "Organization", "name": "Heaven Designs Private Limited" },
  "description": "Structural analysis using STAAD Pro for solar mounting structures. Wind load, dead load, and seismic analysis with stamped engineer reports for rooftop and ground mount solar projects.",
  "url": "https://heavendesigns.in/staad-pro-report-calculations/"
};

const software = [
  { name: 'STAAD Pro', desc: 'Industry-standard structural analysis and design software for solar mounting structures', icon: '🏗️' },
  { name: 'AutoCAD', desc: 'Precision 2D/3D CAD drawings for structural details and general arrangement', icon: '📐' },
  { name: 'SketchUp', desc: '3D modelling for site layout, panel placement, and structure visualisation', icon: '🖥️' },
  { name: 'SolidWorks', desc: 'Detailed 3D modelling of GI/MS mounting structures and custom brackets', icon: '⚙️' },
  { name: 'PVsyst', desc: 'Energy yield simulation integrated with structural tilt and shading optimisation', icon: '☀️' },
];

const deliverables = [
  { title: 'STAAD Pro Analysis Report', desc: 'Complete structural analysis output including node displacements, member forces, and unity check ratios for all structural members.' },
  { title: 'Wind & Dead Load Calculations', desc: 'IS 875 Part 3 compliant wind load analysis with basic wind speed inputs specific to project location and terrain category.' },
  { title: 'Seismic Analysis', desc: 'IS 1893 seismic zone-based analysis ensuring mounting structure performance under earthquake loading conditions.' },
  { title: 'Foundation Design', desc: 'Pile/footing design calculations for ground mount solar structures, covering bearing capacity and settlement checks.' },
  { title: 'Structural Drawing Set', desc: 'AutoCAD drawings showing member sizes, connections, base plate details, and anchor bolt specifications.' },
  { title: 'Bill of Materials', desc: 'Detailed steel quantity take-off with section sizes, grades, lengths, and weights for procurement.' },
];

const stats = [
  { value: '500+', label: 'STAAD Pro Reports Delivered' },
  { value: '50+', label: 'Licensed Structural Engineers' },
  { value: '3–7', label: 'Days Turnaround' },
  { value: '100%', label: 'IS Standard Compliant' },
];
---

<Layout
  title="STAAD Pro Report & Calculations – Heaven Designs | Solar Structural Analysis"
  description="Professional STAAD Pro structural analysis for solar mounting systems. Wind load, seismic, and dead load calculations with stamped reports for rooftop and ground mount solar EPC companies."
  canonical="https://heavendesigns.in/staad-pro-report-calculations/"
  schema={schema}
>
  <Navbar />
  <main>
    <PageHero
      title="STAAD Pro Report & Calculations"
      subtitle="Structural analysis and design calculations for solar mounting systems using industry-standard STAAD Pro software"
      breadcrumbs={[{ label: 'Services', href: '/our-services/' }, { label: 'STAAD Pro Reports' }]}
    />

    <!-- Intro -->
    <section class="py-16 px-4 sm:px-6 bg-white">
      <div class="max-w-7xl mx-auto">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-sm font-bold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Montserrat',sans-serif">
              — STRUCTURAL ENGINEERING
            </p>
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-gray-900 mb-6 leading-tight" style="font-family:'Montserrat',sans-serif">
              Precision Structural Analysis for Solar Mounting Systems
            </h2>
            <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-4" style="font-family:'Poppins',sans-serif">
              Solar design tools help automate the engineering process, enabling solar contractors and EPC companies to deliver quick, accurate, and precise estimations to their clients. Heaven Designs uses STAAD Pro — the industry standard for structural analysis — to ensure every mounting structure is safe, optimised, and code-compliant.
            </p>
            <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-6" style="font-family:'Poppins',sans-serif">
              The platform supports both layout modelling and performance forecasting for solar power plants, simplifying and accelerating the engineering and design process for large-scale installations and complex topographies.
            </p>
            <a href="/contact-us/" class="inline-flex items-center gap-2 bg-[#149C68] text-white font-bold px-6 py-3 rounded-full hover:bg-[#117a52] transition-colors duration-200" style="font-family:'Montserrat',sans-serif">
              Get a Quote
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/></svg>
            </a>
          </div>
          <div class="grid grid-cols-2 gap-4">
            {stats.map((stat) => (
              <div class="bg-gradient-to-br from-[#149C68]/5 to-[#149C68]/10 border border-[#149C68]/20 rounded-2xl p-6 text-center">
                <p class="text-3xl font-black text-[#149C68] mb-1" style="font-family:'Montserrat',sans-serif">{stat.value}</p>
                <p class="text-gray-600 text-sm sm:text-base font-medium" style="font-family:'Poppins',sans-serif">{stat.label}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Deliverables -->
    <section class="py-16 px-4 sm:px-6 bg-gray-50">
      <div class="max-w-7xl mx-auto">
        <p class="text-sm font-bold tracking-widest text-[#149C68] uppercase mb-3 text-center" style="font-family:'Montserrat',sans-serif">
          — DELIVERABLES
        </p>
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-gray-900 mb-4 text-center" style="font-family:'Montserrat',sans-serif">
          What's Included in Every Report
        </h2>
        <p class="text-gray-600 text-center max-w-2xl mx-auto mb-12" style="font-family:'Poppins',sans-serif">
          Every STAAD Pro report is prepared by licensed structural engineers and includes all documentation needed for project execution and regulatory submission.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {deliverables.map((item, i) => (
            <div class="bg-white rounded-2xl p-6 shadow-sm border border-gray-100 hover:border-[#149C68]/30 hover:shadow-md transition-all duration-300">
              <div class="w-10 h-10 bg-[#149C68] rounded-xl flex items-center justify-center text-white font-black text-base mb-4" style="font-family:'Montserrat',sans-serif">
                {String(i + 1).padStart(2, '0')}
              </div>
              <h3 class="font-black text-gray-900 text-base mb-2" style="font-family:'Montserrat',sans-serif">{item.title}</h3>
              <p class="text-gray-500 text-sm sm:text-base leading-relaxed" style="font-family:'Poppins',sans-serif">{item.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Software Tools -->
    <section class="py-16 px-4 sm:px-6 bg-white">
      <div class="max-w-7xl mx-auto">
        <p class="text-sm font-bold tracking-widest text-[#149C68] uppercase mb-3 text-center" style="font-family:'Montserrat',sans-serif">
          — SOFTWARE TOOLS
        </p>
        <h2 class="text-2xl sm:text-3xl font-black text-gray-900 mb-4 text-center" style="font-family:'Montserrat',sans-serif">
          Engineering Software We Use
        </h2>
        <p class="text-gray-600 text-center max-w-2xl mx-auto mb-12" style="font-family:'Poppins',sans-serif">
          We take pride in assisting our EPC clients in reducing project cost by delivering optimised solar design solutions using industry-leading tools.
        </p>
        <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-3 sm:gap-4">
          {software.map((tool) => (
            <div class="bg-gray-50 border border-gray-100 rounded-2xl p-6 text-center hover:border-[#149C68]/30 hover:bg-[#149C68]/5 transition-all duration-300">
              <div class="text-3xl mb-3">{tool.icon}</div>
              <h3 class="font-black text-gray-900 text-lg mb-2" style="font-family:'Montserrat',sans-serif">{tool.name}</h3>
              <p class="text-gray-500 text-xs leading-relaxed" style="font-family:'Poppins',sans-serif">{tool.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>
