const categoryColors: Record<string, string> = {
  'Pre-Design': 'bg-emerald-100 text-emerald-700',
  'Engineering': 'bg-blue-100 text-blue-700',
  'Project Management': 'bg-purple-100 text-purple-700',
  'Permit Design': 'bg-orange-100 text-orange-700',
  'Solar Business': 'bg-amber-100 text-amber-700',
  'Site Survey': 'bg-cyan-100 text-cyan-700',
  'Solar Design': 'bg-green-100 text-green-700',
};

const schema = {
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Heaven Designs Blog",
  "description": "Solar design insights, engineering best practices, and industry news from Heaven Designs.",
  "url": "https://heavendesigns.in/blog/",
  "publisher": {
    "@type": "Organization",
    "name": "Heaven Designs Private Limited",
    "logo": { "@type": "ImageObject", "url": "https://heavendesigns.in/images/logo.webp" }
