---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';
---

<Layout
  title="Our Culture – Heaven Designs | Life at Heaven Designs"
  description="Discover the vibrant culture at Heaven Designs. Team festivals, office trips, training programs and activities that make us a great place to work in Surat, Gujarat."
  canonical="https://heavendesigns.in/our-culture/"
>
  <Navbar />
  <main>
    <PageHero
      title="Our Culture"
      subtitle="Life at Heaven Designs — where great work and great people come together."
      breadcrumbs={[{ label: 'Our Culture' }]}
    />

    <!-- Festivals -->
    <section class="py-16 px-4 sm:px-6 bg-white">
      <div class="max-w-7xl mx-auto">
        <p class="text-sm font-bold tracking-widest text-[#149C68] uppercase mb-2" style="font-family:'Montserrat',sans-serif">— TEAM LIFE</p>
        <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4 leading-tight" style="font-family:'Montserrat',sans-serif">Festivals</h2>
        <p class="text-gray-600 max-w-2xl mb-10" style="font-family:'Poppins',sans-serif">
          At Heaven Designs, we celebrate every festival with full enthusiasm. Diwali, Navratri, Holi — we make every occasion special for our team.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="md:col-span-2 md:row-span-2 overflow-hidden rounded-xl">
            <img src="/images/culture/c1.webp" alt="Team festival celebration" class="w-full h-full object-cover hover:scale-105 transition-transform duration-500" style="min-height:280px" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c13.webp" alt="Festival event" class="w-full h-48 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c14.webp" alt="Office celebration" class="w-full h-48 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c2.webp" alt="Team celebration" class="w-full h-48 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c4.webp" alt="Heaven Designs event" class="w-full h-48 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- Our Trips -->
    <section class="py-16 px-4 sm:px-6 bg-gray-50">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4 leading-tight" style="font-family:'Montserrat',sans-serif">Our Trips</h2>
        <p class="text-gray-600 max-w-2xl mb-10" style="font-family:'Poppins',sans-serif">
          Annual team trips to Polo Forest, Saputara, Statue of Unity and beyond. These journeys recharge our energy and strengthen our bonds.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c3.webp" alt="Saputara trip" class="w-full h-56 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c5.webp" alt="Team outing" class="w-full h-56 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c15.webp" alt="Statue of Unity trip" class="w-full h-56 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c6.webp" alt="Trip memory" class="w-full h-56 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c12.webp" alt="Annual trip" class="w-full h-56 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c11.webp" alt="Team adventure" class="w-full h-56 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- Team Training -->
    <section class="py-16 px-4 sm:px-6 bg-white">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4 leading-tight" style="font-family:'Montserrat',sans-serif">Team Training</h2>
        <p class="text-gray-600 max-w-2xl mb-10" style="font-family:'Poppins',sans-serif">
          Continuous learning keeps us sharp. Regular workshops, software training, and knowledge-sharing sessions help our team stay ahead in solar engineering.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c9.webp" alt="Training session" class="w-full h-56 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c10.webp" alt="Team workshop" class="w-full h-56 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/culture/c16.webp" alt="Office training" class="w-full h-56 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <!-- Our Office -->
    <section class="py-16 px-4 sm:px-6 bg-gray-50">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4 leading-tight" style="font-family:'Montserrat',sans-serif">Our Office</h2>
        <p class="text-gray-600 max-w-2xl mb-10" style="font-family:'Poppins',sans-serif">
          Our vibrant offices in Surat and Ahmedabad are designed for collaboration, creativity, and comfort. A space where great ideas come to life.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="overflow-hidden rounded-xl">
            <img src="/images/about/banner.webp" alt="Heaven Designs office team" class="w-full h-72 object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="grid grid-cols-2 gap-4">
            <div class="overflow-hidden rounded-xl">
              <img src="/images/culture/c7.webp" alt="Office interior" class="w-full h-[136px] object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="overflow-hidden rounded-xl">
              <img src="/images/culture/c8.webp" alt="Work environment" class="w-full h-[136px] object-cover hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
            <div class="col-span-2 overflow-hidden rounded-xl">
              <img src="/images/about/team-1.webp" alt="Team at office" class="w-full h-[136px] object-cover object-top hover:scale-105 transition-transform duration-500" loading="lazy" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Team Activities -->
    <section class="py-16 px-4 sm:px-6 bg-white">
      <div class="max-w-7xl mx-auto">
        <h2 class="text-3xl sm:text-4xl font-black text-gray-900 mb-4 leading-tight" style="font-family:'Montserrat',sans-serif">Team Activities</h2>
        <p class="text-gray-600 max-w-2xl mb-10" style="font-family:'Poppins',sans-serif">
          From sports days to team lunches, we make time to have fun together. A healthy team culture leads to better collaboration and productivity.
        </p>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          <div class="overflow-hidden rounded-xl">
            <img src="/images/about/team-2.webp" alt="Team activity" class="w-full h-48 object-cover object-top hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/about/team-3.webp" alt="Team engagement" class="w-full h-48 object-cover object-top hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/about/team-4.webp" alt="Fun at work" class="w-full h-48 object-cover object-top hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
          <div class="overflow-hidden rounded-xl">
            <img src="/images/about/keyur.webp" alt="Team recognition" class="w-full h-48 object-cover object-top hover:scale-105 transition-transform duration-500" loading="lazy" />
          </div>
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>
