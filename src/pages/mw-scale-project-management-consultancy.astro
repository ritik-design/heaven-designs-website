---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "MW Scale Project Management Consultancy",
  "provider": { "@type": "Organization", "name": "Heaven Designs Private Limited" },
  "description": "End-to-end project management for utility-scale solar projects",
  "url": "https://heavendesigns.in/mw-scale-project-management-consultancy/",
  "areaServed": "Worldwide"
};

const keyServices = [
  {
    title: "Project Planning & Feasibility",
    desc: "Comprehensive feasibility studies, resource assessment, and project scheduling",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>`,
  },
  {
    title: "Design & Engineering Support",
    desc: "Coordination with design teams for engineering deliverables",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>`,
  },
  {
    title: "Procurement & Vendor Management",
    desc: "Strategic sourcing, vendor evaluation, and procurement optimization",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>`,
  },
  {
    title: "Construction Management",
    desc: "On-site supervision, contractor coordination, and milestone tracking",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>`,
  },
  {
    title: "Quality Assurance & Control",
    desc: "QA/QC protocols, inspection reports, and compliance documentation",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    title: "Commissioning & Handover",
    desc: "System testing, performance verification, and smooth project handover",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>`,
  },
  {
    title: "Risk Management & Compliance",
    desc: "Regulatory compliance, risk identification, and mitigation strategies",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>`,
  },
];

const benefits = [
  {
    num: "01",
    title: "Efficiency",
    desc: "Streamlined project delivery with reduced timelines through expert coordination",
  },
  {
    num: "02",
    title: "Cost-Effectiveness",
    desc: "Optimized procurement and resource allocation minimizes project costs",
  },
  {
    num: "03",
    title: "Reliability",
    desc: "Proven methodologies ensure consistent quality and on-time delivery",
  },
];

const galleryImages = [
  { src: "/images/services/s2/hero.webp", alt: "MW Scale Project Management" },
  { src: "/images/services/s2/img1.webp", alt: "Project Management Consultancy" },
  { src: "/images/services/s2/img2.webp", alt: "Solar PMC Services" },
];
---

<Layout
  title="MW Scale Project Management & Consultancy – Heaven Designs"
  description="End-to-end project management consultancy for utility-scale solar projects. Expert procurement, construction management, QA/QC and commissioning support."
  canonical="https://heavendesigns.in/mw-scale-project-management-consultancy/"
  schema={schema}
>
  <Navbar />
  <main>
    <PageHero
      title="MW Scale Project Management Consultancy"
      subtitle="End-to-end project management for utility-scale solar projects, from feasibility through commissioning."
      breadcrumbs={[
        { label: "Our Services", href: "/our-services/" },
        { label: "MW Scale Project Management Consultancy" },
      ]}
    />

    <!-- Section 1: Intro -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-sm font-semibold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Poppins',sans-serif">
              — PROJECT MANAGEMENT
            </p>
            <h2 class="text-3xl sm:text-4xl font-black text-[#0f172a] mb-6" style="font-family:'Montserrat',sans-serif">
              MW Scale Project Management Consultancy
            </h2>
            <p class="text-gray-600 leading-relaxed text-lg mb-8" style="font-family:'Poppins',sans-serif">
              Heaven Designs provides comprehensive project management consultancy services for utility-scale solar projects. Our experienced team guides EPC companies from initial feasibility through commissioning.
            </p>
            <a
              href="/contact-us/"
              class="inline-block px-8 py-3 bg-[#FFA91F] text-white font-semibold rounded hover:bg-[#e8970d] transition-colors"
              style="font-family:'Poppins',sans-serif"
            >
              Get a Free Consultation
            </a>
          </div>
          <div>
            <img
              src="/images/services/s2/hero.webp"
              alt="MW Scale Project Management Consultancy"
              class="w-full rounded-xl shadow-lg object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Key Services -->
    <section class="py-16 bg-[#f9fafb]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <p class="text-sm font-semibold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Poppins',sans-serif">
            — SCOPE OF WORK
          </p>
          <h2 class="text-3xl sm:text-4xl font-black text-[#0f172a]" style="font-family:'Montserrat',sans-serif">
            Key Points
          </h2>
        </div>
        <div class="grid sm:grid-cols-2 gap-6">
          {keyServices.map((service) => (
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 flex items-start gap-4 hover:shadow-md transition-shadow">
              <div class="shrink-0 w-10 h-10 flex items-center justify-center rounded-full bg-[#149C68]/10">
                <svg class="w-5 h-5 text-[#149C68]" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={service.icon} />
              </div>
              <div>
                <h3 class="font-bold text-[#0f172a] mb-1" style="font-family:'Montserrat',sans-serif">{service.title}</h3>
                <p class="text-gray-600 text-lg leading-relaxed" style="font-family:'Poppins',sans-serif">{service.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 3: Benefits -->
    <section class="py-16 bg-[#149C68]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="text-3xl sm:text-4xl font-black text-white mb-12 text-center" style="font-family:'Montserrat',sans-serif">
          Benefits
        </h2>
        <div class="grid sm:grid-cols-3 gap-6">
          {benefits.map((b) => (
            <div class="bg-white/10 border border-white/20 rounded-xl p-8">
              <p class="text-[#FFA91F] font-black text-2xl mb-3" style="font-family:'Montserrat',sans-serif">{b.num} — {b.title}</p>
              <p class="text-white/90 leading-relaxed text-lg" style="font-family:'Poppins',sans-serif">{b.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 4: Gallery -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="text-3xl sm:text-4xl font-black text-[#0f172a] mb-10 text-center" style="font-family:'Montserrat',sans-serif">
          Project Gallery
        </h2>
        <div class="grid sm:grid-cols-3 gap-6">
          {galleryImages.map((img) => (
            <div class="overflow-hidden rounded-xl shadow-md">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-56 object-cover hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>
