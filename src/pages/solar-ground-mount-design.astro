---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';

const services = [
  {
    title: "Optimal Row Spacing",
    desc: "Precise inter-row spacing calculations for maximum energy yield and minimal shading losses",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 10h16M4 14h16M4 18h16"/>`,
  },
  {
    title: "Structural Design",
    desc: "Ground-mount racking and foundation structural engineering for all soil conditions",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>`,
  },
  {
    title: "Civil & Foundation",
    desc: "Site grading, drainage design, and foundation engineering for solar farm installations",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>`,
  },
  {
    title: "Electrical Design",
    desc: "DC and AC electrical layout, string sizing, and single-line diagrams for ground-mount systems",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
];
---

<Layout
  title="Solar Ground Mount Design – Heaven Designs | Utility Scale Engineering"
  description="Professional solar ground mount design services for utility and commercial scale projects. Row spacing optimization, structural design, and civil engineering."
  canonical="https://heavendesigns.in/solar-ground-mount-design/"
>
  <Navbar />
  <main>
    <PageHero
      title="Solar Ground Mount Design"
      subtitle="Optimized ground-mount solar designs for utility-scale and commercial projects."
      breadcrumbs={[
        { label: "Our Services", href: "/our-services/" },
        { label: "Solar Ground Mount Design" },
      ]}
    />

    <!-- Section 1: Intro -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-sm font-semibold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Poppins',sans-serif">
              — GROUND MOUNT
            </p>
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-[#0f172a] mb-6" style="font-family:'Montserrat',sans-serif">
              Solar Ground Mount Design
            </h2>
            <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-8" style="font-family:'Poppins',sans-serif">
              Heaven Designs specializes in ground-mounted solar system design for utility-scale and commercial projects. Our engineering team delivers optimized layouts, structural designs, and civil engineering packages for large-scale solar farms.
            </p>
            <a
              href="/contact-us/"
              class="inline-block px-8 py-3 bg-[#FFA91F] text-white font-semibold rounded hover:bg-[#e8970d] transition-colors"
              style="font-family:'Poppins',sans-serif"
            >
              Request a Quote
            </a>
          </div>
          <div>
            <img
              src="/images/services/service-1.webp"
              alt="Solar Ground Mount Design"
              class="w-full rounded-xl shadow-lg object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: Services -->
    <section class="py-16 bg-[#f9fafb]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-[#0f172a] mb-12 text-center" style="font-family:'Montserrat',sans-serif">
          What We Design
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {services.map((s) => (
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center hover:shadow-md transition-shadow">
              <div class="w-12 h-12 flex items-center justify-center rounded-full bg-[#149C68]/10 mx-auto mb-4">
                <svg class="w-6 h-6 text-[#149C68]" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={s.icon} />
              </div>
              <h3 class="font-bold text-[#0f172a] mb-2" style="font-family:'Montserrat',sans-serif">{s.title}</h3>
              <p class="text-gray-600 text-sm sm:text-base leading-relaxed" style="font-family:'Poppins',sans-serif">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>
