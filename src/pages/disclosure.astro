---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout
  title="Disclosure – Heaven Designs"
  description="Disclosure statement for Heaven Designs Private Limited. Transparency about our affiliations, content, and service guarantees."
  canonical="https://heavendesigns.in/disclosure/"
  noindex={true}
>
  <Navbar />
  <main>
    <PageHero
      title="Disclosure"
      subtitle="Transparency about our affiliations, content, and the nature of our services"
      breadcrumbs={[{ label: 'Disclosure' }]}
    />

    <section class="py-16 px-4 sm:px-6 bg-white">
      <div class="max-w-3xl mx-auto" style="font-family:'Poppins',sans-serif">
        <p class="text-gray-500 text-sm mb-8">Last updated: November 2024</p>

        <h2 class="text-2xl font-black text-gray-900 mb-4" style="font-family:'Montserrat',sans-serif">Platform Affiliation Disclosure</h2>
        <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-6">
          This site is not a part of the Facebook™ (or LinkedIn) website or Facebook™ Inc. / LinkedIn Corporation. Additionally, this site is not endorsed by Facebook™ or LinkedIn in any way. FACEBOOK™ is a trademark of FACEBOOK™, Inc.
        </p>

        <h2 class="text-2xl font-black text-gray-900 mb-4" style="font-family:'Montserrat',sans-serif">No Earnings Guarantee</h2>
        <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-4">
          Heaven Designs provides solar design, engineering, and consultancy services. While we share information, strategies, and case studies about solar project outcomes, we do not guarantee any specific business results or financial outcomes from using our services.
        </p>
        <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-6">
          Results mentioned in our marketing materials, case studies, or testimonials represent specific client experiences and are not typical. Individual project results will vary based on project scale, location, client inputs, regulatory environment, and other factors beyond our control.
        </p>

        <h2 class="text-2xl font-black text-gray-900 mb-4" style="font-family:'Montserrat',sans-serif">Educational Content</h2>
        <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-6">
          Content published on our website — including blog posts, guides, and resource materials — is intended for educational and informational purposes only. It represents our team's knowledge and experience in solar design engineering and should not be construed as site-specific engineering advice for your project.
        </p>

        <h2 class="text-2xl font-black text-gray-900 mb-4" style="font-family:'Montserrat',sans-serif">Our Integrity Standards</h2>
        <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-6">
          Heaven Designs is committed to operating with the highest standards of integrity and transparency. We do not endorse third-party products or services through affiliate arrangements on this website. Any software tools, products, or services mentioned are referenced for educational context only.
        </p>

        <h2 class="text-2xl font-black text-gray-900 mb-4" style="font-family:'Montserrat',sans-serif">Contact Us</h2>
        <p class="text-gray-600 leading-relaxed text-sm sm:text-base">
          If you have questions about this disclosure, please contact us at{' '}
          <a href="mailto:service@heavendesigns.in" class="text-[#149C68] hover:underline">service@heavendesigns.in</a>.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
