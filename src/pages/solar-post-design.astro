---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';

const deliverables = [
  {
    title: "Detailed Layout Drawings",
    desc: "Complete CAD drawings for panel placement and wiring",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>`,
  },
  {
    title: "Structural Calculations",
    desc: "Foundation, mounting structure, and load analysis",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>`,
  },
  {
    title: "CEIG Electrical Drawings",
    desc: "Single-line, three-line, and schematic diagrams",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
  {
    title: "As-Built Documentation",
    desc: "Final documentation package for permits and handover",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/>`,
  },
];
---

<Layout
  title="Solar Post-Design Services – Heaven Designs | Detailed Engineering Design"
  description="Complete solar post-design engineering services. Detailed layout drawings, structural analysis, CEIG drawings, and as-built documentation for EPC companies."
  canonical="https://heavendesigns.in/solar-post-design/"
>
  <Navbar />
  <main>
    <PageHero
      title="Solar Post-Design"
      subtitle="Complete detailed engineering packages including layout drawings, structural calculations, and CEIG documentation."
      breadcrumbs={[
        { label: "Our Services", href: "/our-services/" },
        { label: "Solar Post-Design" },
      ]}
    />

    <!-- Section 1: Intro -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-sm font-semibold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Poppins',sans-serif">
              — POST DESIGN
            </p>
            <h2 class="text-3xl sm:text-4xl font-black text-[#0f172a] mb-6" style="font-family:'Montserrat',sans-serif">
              Solar Post-Design
            </h2>
            <p class="text-gray-600 leading-relaxed mb-8" style="font-family:'Poppins',sans-serif">
              Solar Post-Design is the detailed engineering phase following preliminary design approval. Heaven Designs delivers complete engineering packages including detailed layout drawings, structural calculations, and CEIG documentation required for project execution.
            </p>
            <a
              href="/contact-us/"
              class="inline-block px-8 py-3 bg-[#FFA91F] text-white font-semibold rounded hover:bg-[#e8970d] transition-colors"
              style="font-family:'Poppins',sans-serif"
            >
              Get Started
            </a>
          </div>
          <div>
            <img
              src="/images/services/service-2.webp"
              alt="Solar Post-Design Engineering"
              class="w-full rounded-xl shadow-lg object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: What We Deliver -->
    <section class="py-16 bg-[#f9fafb]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="text-3xl sm:text-4xl font-black text-[#0f172a] mb-12 text-center" style="font-family:'Montserrat',sans-serif">
          What We Deliver
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {deliverables.map((d) => (
            <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100 text-center hover:shadow-md transition-shadow">
              <div class="w-12 h-12 flex items-center justify-center rounded-full bg-[#149C68]/10 mx-auto mb-4">
                <svg class="w-6 h-6 text-[#149C68]" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={d.icon} />
              </div>
              <h3 class="font-bold text-[#0f172a] mb-2" style="font-family:'Montserrat',sans-serif">{d.title}</h3>
              <p class="text-gray-600 text-sm leading-relaxed" style="font-family:'Poppins',sans-serif">{d.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>
