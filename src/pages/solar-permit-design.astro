---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": "Solar Permit Design",
  "provider": { "@type": "Organization", "name": "Heaven Designs Private Limited" },
  "areaServed": ["United States", "Canada"],
  "url": "https://heavendesigns.in/solar-permit-design/"
};

const deliverablesLeft = [
  "Site plan",
  "Roof plan",
  "Cover Sheet",
  "Attachment detail",
  "Signage",
];

const deliverablesRight = [
  "Single line & three line diagrams",
  "String layout & bill of material",
  "Equipment specifications & calculations",
  "Equipment data sheet",
];

const features = [
  {
    title: "Live Dashboard",
    desc: "Track your project status in real-time",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>`,
  },
  {
    title: "No Extra Charge for Revision",
    desc: "Unlimited revisions included",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>`,
  },
  {
    title: "24/7 Available for Service",
    desc: "Round-the-clock support",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>`,
  },
  {
    title: "Talented Design Team",
    desc: "Experienced permit design specialists",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>`,
  },
  {
    title: "Live Chat with Designer",
    desc: "Direct communication with your assigned designer",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>`,
  },
  {
    title: "Quick Delivery",
    desc: "Standard 24-48 hour turnaround",
    icon: `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>`,
  },
];

const galleryImages = [
  { src: "/images/services/s5/hero.webp", alt: "Solar Permit Design" },
  { src: "/images/services/s5/img1.webp", alt: "Permit Plan Set" },
  { src: "/images/services/s5/img2.webp", alt: "Permit Design Documents" },
];
---

<Layout
  title="Solar Permit Design Services – Heaven Designs | US & Canada Permit Plan Sets"
  description="Professional solar permit design for US and Canada residential and commercial projects. Complete permit plan sets with site plans, single-line diagrams, and equipment specs."
  canonical="https://heavendesigns.in/solar-permit-design/"
  schema={schema}
>
  <Navbar />
  <main>
    <PageHero
      title="Solar Permit Design"
      subtitle="Complete permit plan sets for US and Canada residential and commercial solar projects."
      breadcrumbs={[
        { label: "Our Services", href: "/our-services/" },
        { label: "Solar Permit Design" },
      ]}
    />

    <!-- Section 1: Intro -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <p class="text-sm font-semibold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Poppins',sans-serif">
              — PERMIT DESIGN
            </p>
            <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-[#0f172a] mb-6" style="font-family:'Montserrat',sans-serif">
              Solar Permit Design
            </h2>
            <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-8" style="font-family:'Poppins',sans-serif">
              Heaven Designs provides professional solar permit plan sets for residential and commercial projects in the US and Canada. Our detailed drawings meet all AHJ requirements for fast permit approvals.
            </p>
            <a
              href="/contact-us/"
              class="inline-block px-8 py-3 bg-[#FFA91F] text-white font-semibold rounded hover:bg-[#e8970d] transition-colors"
              style="font-family:'Poppins',sans-serif"
            >
              Get a Permit Quote
            </a>
          </div>
          <div>
            <img
              src="/images/services/s5/hero.webp"
              alt="Solar Permit Design Services"
              class="w-full rounded-xl shadow-lg object-cover"
              loading="eager"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- Section 2: What's Included -->
    <section class="py-16 bg-[#f9fafb]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="text-center mb-12">
          <p class="text-sm font-semibold tracking-widest text-[#149C68] uppercase mb-3" style="font-family:'Poppins',sans-serif">
            — DELIVERABLES
          </p>
          <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-[#0f172a]" style="font-family:'Montserrat',sans-serif">
            Our Detailed Residential Permit Planset Includes
          </h2>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 max-w-4xl mx-auto">
          <div class="grid sm:grid-cols-2 gap-6">
            <ul class="space-y-3">
              {deliverablesLeft.map((item) => (
                <li class="flex items-center gap-3">
                  <span class="shrink-0 w-6 h-6 flex items-center justify-center rounded-full bg-[#149C68]">
                    <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                    </svg>
                  </span>
                  <span class="text-gray-700" style="font-family:'Poppins',sans-serif">{item}</span>
                </li>
              ))}
            </ul>
            <ul class="space-y-3">
              {deliverablesRight.map((item) => (
                <li class="flex items-center gap-3">
                  <span class="shrink-0 w-6 h-6 flex items-center justify-center rounded-full bg-[#149C68]">
                    <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/>
                    </svg>
                  </span>
                  <span class="text-gray-700" style="font-family:'Poppins',sans-serif">{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- Section 3: Why Choose Us -->
    <section class="py-16 bg-[#149C68]">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-white mb-12 text-center" style="font-family:'Montserrat',sans-serif">
          Main Reasons Why Choose Us
        </h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {features.map((f) => (
            <div class="bg-white rounded-xl p-6 shadow-sm">
              <div class="w-10 h-10 flex items-center justify-center rounded-full bg-[#149C68]/10 mb-4">
                <svg class="w-5 h-5 text-[#149C68]" fill="none" stroke="currentColor" viewBox="0 0 24 24" set:html={f.icon} />
              </div>
              <h3 class="font-bold text-[#0f172a] mb-2" style="font-family:'Montserrat',sans-serif">{f.title}</h3>
              <p class="text-gray-600 text-sm sm:text-base leading-relaxed" style="font-family:'Poppins',sans-serif">{f.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Section 4: Gallery -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-[#0f172a] mb-10 text-center" style="font-family:'Montserrat',sans-serif">
          Project Gallery
        </h2>
        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-5 sm:gap-6">
          {galleryImages.map((img) => (
            <div class="overflow-hidden rounded-xl shadow-md">
              <img
                src={img.src}
                alt={img.alt}
                class="w-full h-56 object-cover hover:scale-105 transition-transform duration-300"
                loading="lazy"
              />
            </div>
          ))}
        </div>
      </div>
    </section>

    <CTABanner />
  </main>
  <Footer />
</Layout>
