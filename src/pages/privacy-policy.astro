---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import PageHero from '../components/PageHero.astro';
---

<Layout
  title="Privacy Policy – Heaven Designs"
  description="Read the privacy policy of Heaven Designs Private Limited. Learn how we collect, use, and protect your personal information."
  canonical="https://heavendesigns.in/privacy-policy/"
  noindex={true}
>
  <Navbar />
  <main>
    <PageHero
      title="Privacy Policy"
      subtitle="How we collect, use, and protect your information"
      breadcrumbs={[{ label: 'Privacy Policy' }]}
    />

    <section class="py-16 px-4 sm:px-6 bg-white">
      <div class="max-w-3xl mx-auto prose prose-gray" style="font-family:'Poppins',sans-serif">
        <p class="text-gray-500 text-sm mb-8">Last updated: November 2024</p>

        <h2 class="text-2xl font-black text-gray-900 mb-4" style="font-family:'Montserrat',sans-serif">1. Information We Collect</h2>
        <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-6">
          Heaven Designs Private Limited collects information you provide directly to us when you fill out contact forms, request quotes, or communicate with our team. This includes your name, email address, phone number, company name, and project details.
        </p>

        <h2 class="text-2xl font-black text-gray-900 mb-4" style="font-family:'Montserrat',sans-serif">2. How We Use Your Information</h2>
        <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-4">We use the information we collect to:</p>
        <ul class="text-gray-600 leading-relaxed text-sm sm:text-base mb-6 space-y-2 list-disc list-inside">
          <li>Respond to your inquiries and provide solar design services</li>
          <li>Send you project-related communications and updates</li>
          <li>Improve our services and website experience</li>
          <li>Comply with legal obligations</li>
        </ul>

        <h2 class="text-2xl font-black text-gray-900 mb-4" style="font-family:'Montserrat',sans-serif">3. Information Sharing</h2>
        <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-6">
          We do not sell, trade, or otherwise transfer your personal information to outside parties. We may share information with trusted third parties who assist us in operating our website and conducting our business, as long as those parties agree to keep this information confidential.
        </p>

        <h2 class="text-2xl font-black text-gray-900 mb-4" style="font-family:'Montserrat',sans-serif">4. Data Security</h2>
        <p class="text-gray-600 leading-relaxed text-sm sm:text-base mb-6">
          We implement appropriate security measures to protect your personal information against unauthorized access, alteration, disclosure, or destruction.
        </p>

        <h2 class="text-2xl font-black text-gray-900 mb-4" style="font-family:'Montserrat',sans-serif">5. Contact Us</h2>
        <p class="text-gray-600 leading-relaxed text-sm sm:text-base">
          If you have questions about this privacy policy, please contact us at <a href="mailto:service@heavendesigns.in" class="text-[#149C68] hover:underline">service@heavendesigns.in</a>.
        </p>
      </div>
    </section>
  </main>
  <Footer />
</Layout>
