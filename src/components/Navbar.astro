---
const navLinks = [
  { label: 'Home', href: '/', active: true },
  { label: 'About Us', href: '/about-us/' },
  {
    label: 'Our Culture',
    href: '/our-culture/',
    children: [
      { label: 'Join Our Team', href: '/join-our-team/' },
    ],
  },
  { label: 'Our Projects', href: '/our-projects/' },
  {
    label: 'Our Services',
    href: '/our-services/',
    children: [
      { label: 'Solar 3D Pre-Design', href: '/solar-3d-pre-design/' },
      { label: 'Solar Post-Design', href: '/solar-post-design/' },
      { label: 'Solar Rooftop Detailed Engineering Design', href: '/solar-rooftop-detailed-engineering-design/' },
      { label: 'Solar Ground Mount Design', href: '/solar-ground-mount-design/' },
      { label: 'MW Scale Project Management Consultancy', href: '/mw-scale-project-management-consultancy/' },
      { label: 'Solar Civil And Structural Engineering', href: '/solar-civil-and-structural-engineering-3/' },
      { label: 'Site Survey & Land Feasibility Services', href: '/site-survey-land-feasibility-services/' },
      { label: 'Solar Permit Design', href: '/solar-permit-design/' },
      { label: 'Reports', href: '/reports/' },
    ],
  },
  {
    label: 'Resource Center',
    href: '/resource-center/',
    children: [
      { label: 'Samples & Checklist', href: '/samples-checklist/' },
      { label: 'FAQs', href: '/faqs/' },
      { label: 'Our Blog', href: '/our-blog/' },
      { label: 'Join Our Team', href: '/join-our-team/' },
    ],
  },
  { label: 'Contact Us', href: '/contact-us/' },
];
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white shadow-sm">
  <nav class="max-w-7xl mx-auto px-4 sm:px-6 flex items-center justify-between h-[70px]">

    <!-- Logo -->
    <a href="/" class="flex items-center shrink-0">
      <img src="/images/logo.webp" alt="Heaven Designs" class="h-14 w-auto object-contain" />
    </a>

    <!-- Desktop nav -->
    <ul class="hidden lg:flex items-center gap-0">
      {navLinks.map((link) =>
        link.children ? (
          <li class="relative group">
            <button class={`flex items-center gap-1 px-3.5 py-2 text-[13.5px] font-semibold transition-colors ${link.active ? 'text-[#FFA91F]' : 'text-[#334155] hover:text-[#149C68]'}`}
              style="font-family:'Montserrat',sans-serif">
              {link.label}
              <svg class="w-3 h-3 opacity-60" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
              </svg>
            </button>
            <div class="absolute top-full left-0 pt-1 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
              <div class="bg-white border border-gray-100 shadow-lg py-1.5 min-w-[260px] rounded-sm">
                {link.children.map((child) => (
                  <a href={child.href}
                    class="block px-5 py-2 text-[13px] text-[#334155] hover:bg-[#149C68]/5 hover:text-[#149C68] transition-colors"
                    style="font-family:'Montserrat',sans-serif">
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          </li>
        ) : (
          <li>
            <a href={link.href}
              class={`block px-3.5 py-2 text-[13.5px] font-semibold transition-colors ${link.active ? 'text-[#FFA91F]' : 'text-[#334155] hover:text-[#149C68]'}`}
              style="font-family:'Montserrat',sans-serif">
              {link.label}
            </a>
          </li>
        )
      )}
    </ul>

    <!-- Register button -->
    <div class="hidden lg:flex items-center">
      <a href="https://app.heavendesigns.in/register" class="btn-register">
        Register Now
      </a>
    </div>

    <!-- Mobile toggle -->
    <button id="mob-btn" class="lg:hidden p-2 text-[#334155]">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </nav>

  <!-- Mobile menu -->
  <div id="mob-menu" class="hidden lg:hidden bg-white border-t border-gray-100 px-4 py-3 max-h-[calc(100vh-70px)] overflow-y-auto">
    {navLinks.map((link) =>
      link.children ? (
        <details class="mob-acc group border-b border-gray-100 last:border-b-0">
          <summary class={`flex items-center justify-between px-3 py-3 text-sm font-semibold cursor-pointer list-none ${link.active ? 'text-[#FFA91F]' : 'text-[#334155]'}`}
            style="font-family:'Montserrat',sans-serif">
            <a href={link.href} class="flex-1">{link.label}</a>
            <svg class="w-4 h-4 opacity-60 transition-transform group-open:rotate-180 shrink-0 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <div class="pl-4 pb-2 space-y-0.5">
            {link.children.map((child) => (
              <a href={child.href}
                class="block px-3 py-2 text-[13px] text-[#334155] hover:text-[#149C68] rounded"
                style="font-family:'Montserrat',sans-serif">
                {child.label}
              </a>
            ))}
          </div>
        </details>
      ) : (
        <a href={link.href}
          class={`block px-3 py-3 text-sm font-semibold border-b border-gray-100 last:border-b-0 ${link.active ? 'text-[#FFA91F]' : 'text-[#334155]'}`}
          style="font-family:'Montserrat',sans-serif">
          {link.label}
        </a>
      )
    )}
    <div class="pt-4 pb-2">
      <a href="https://app.heavendesigns.in/register" class="btn-register inline-block">Register Now</a>
    </div>
  </div>
</header>

<script>
  document.getElementById('mob-btn')?.addEventListener('click', () => {
    document.getElementById('mob-menu')?.classList.toggle('hidden');
  });
</script>

<style>
  .mob-acc summary::-webkit-details-marker { display: none; }
</style>
