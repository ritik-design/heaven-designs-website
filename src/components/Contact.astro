---
const services = [
  'Solar 3D Pre-Design',
  'Solar Post-Design',
  'Solar Rooftop Detailed Engineering Design',
  'Solar Ground Mount Design',
  'MW Scale Project Management Consultancy',
  'Solar Civil And Structural Engineering',
  'Site Survey & Land Feasibility Services',
  'Solar Permit Design',
  'Reports',
];
---

<section class="py-20 bg-gray-50 border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="grid lg:grid-cols-2 gap-14 items-start">

      <!-- Left: Info -->
      <div>
        <p class="section-label">Contact</p>
        <h2 class="text-3xl sm:text-4xl font-black text-[#1a1a1a] mb-5" style="font-family:'Montserrat',sans-serif">
          Contact Information
        </h2>
        <p class="text-[#334155] mb-8 leading-relaxed">
          Reach out to us and our team will get back to you within 2 business hours. We serve clients Mon–Sun, 8 AM – 6 PM IST.
        </p>

        <div class="space-y-5">
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-full bg-[#149C68]/15 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-[#149C68]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-[#1a1a1a] text-lg" style="font-family:'Montserrat',sans-serif">Phone</div>
              <a href="tel:+919081100297" class="text-[#334155] hover:text-[#149C68] transition-colors text-lg">+91 90811 00297</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-full bg-[#149C68]/15 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-[#149C68]" fill="currentColor" viewBox="0 0 20 20">
                <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
                <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-[#1a1a1a] text-lg" style="font-family:'Montserrat',sans-serif">Email</div>
              <a href="mailto:service@heavendesigns.in" class="text-[#334155] hover:text-[#149C68] transition-colors text-lg">service@heavendesigns.in</a>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-full bg-[#149C68]/15 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-[#149C68]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-[#1a1a1a] text-lg" style="font-family:'Montserrat',sans-serif">Surat Office</div>
              <p class="text-[#334155] text-lg">204 Anupam Square, Mota Varachha, Surat, Gujarat</p>
            </div>
          </div>

          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-full bg-[#149C68]/15 flex items-center justify-center shrink-0">
              <svg class="w-5 h-5 text-[#149C68]" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <div class="font-semibold text-[#1a1a1a] text-lg" style="font-family:'Montserrat',sans-serif">Ahmedabad Office</div>
              <p class="text-[#334155] text-lg">B1-404 Palladium, Corporate Road, Ahmedabad, Gujarat</p>
            </div>
          </div>
        </div>
      </div>

      <!-- Right: Form -->
      <div class="bg-white border border-gray-100 rounded-xl p-8 shadow-sm">
        <h3 class="text-xl font-bold text-[#1a1a1a] mb-6" style="font-family:'Montserrat',sans-serif">
          Our Quote Team
        </h3>
        <form class="space-y-4">
          <div class="grid sm:grid-cols-2 gap-4">
            <div>
              <label class="block text-xs font-semibold text-[#334155] mb-1.5 uppercase tracking-wide" style="font-family:'Montserrat',sans-serif">First Name</label>
              <input type="text" placeholder="First name" class="w-full border border-gray-200 rounded px-4 py-2.5 text-lg text-[#334155] focus:outline-none focus:border-[#149C68] transition-colors"/>
            </div>
            <div>
              <label class="block text-xs font-semibold text-[#334155] mb-1.5 uppercase tracking-wide" style="font-family:'Montserrat',sans-serif">Last Name</label>
              <input type="text" placeholder="Last name" class="w-full border border-gray-200 rounded px-4 py-2.5 text-lg text-[#334155] focus:outline-none focus:border-[#149C68] transition-colors"/>
            </div>
          </div>

          <div>
            <label class="block text-xs font-semibold text-[#334155] mb-1.5 uppercase tracking-wide" style="font-family:'Montserrat',sans-serif">Email</label>
            <input type="email" placeholder="your@email.com" class="w-full border border-gray-200 rounded px-4 py-2.5 text-lg text-[#334155] focus:outline-none focus:border-[#149C68] transition-colors"/>
          </div>

          <div>
            <label class="block text-xs font-semibold text-[#334155] mb-1.5 uppercase tracking-wide" style="font-family:'Montserrat',sans-serif">Phone</label>
            <input type="tel" placeholder="+91 98765 43210" class="w-full border border-gray-200 rounded px-4 py-2.5 text-lg text-[#334155] focus:outline-none focus:border-[#149C68] transition-colors"/>
          </div>

          <div>
            <label class="block text-xs font-semibold text-[#334155] mb-1.5 uppercase tracking-wide" style="font-family:'Montserrat',sans-serif">Service</label>
            <select class="w-full border border-gray-200 rounded px-4 py-2.5 text-lg text-[#334155] focus:outline-none focus:border-[#149C68] transition-colors bg-white">
              <option value="">Select a service</option>
              {services.map((s) => <option value={s}>{s}</option>)}
            </select>
          </div>

          <div>
            <label class="block text-xs font-semibold text-[#334155] mb-1.5 uppercase tracking-wide" style="font-family:'Montserrat',sans-serif">Message</label>
            <textarea rows={4} placeholder="Tell us about your project..." class="w-full border border-gray-200 rounded px-4 py-2.5 text-lg text-[#334155] focus:outline-none focus:border-[#149C68] transition-colors resize-none"></textarea>
          </div>

          <button type="submit" class="w-full bg-[#149C68] hover:bg-[#0e7a52] text-white font-bold py-3 rounded transition-colors duration-200 text-sm" style="font-family:'Poppins',sans-serif">
            Send Message
          </button>
        </form>
      </div>
    </div>
  </div>
</section>
