---
// logos 1–21 downloaded from the site
const logos = Array.from({ length: 21 }, (_, i) => ({
  src: `/images/clients/logo-${i + 1}.webp`,
  alt: `Client ${i + 1}`,
}));
---

<section class="py-12 sm:py-16 bg-white overflow-hidden border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 mb-8 sm:mb-10 text-center">
    <p class="section-label">Trusted Partner</p>
    <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-[#1a1a1a]" style="font-family:'Montserrat',sans-serif">
      Our Valuable Clients
    </h2>
  </div>

  <div class="relative overflow-hidden">
    <!-- Fade edges -->
    <div class="absolute inset-y-0 left-0 w-12 sm:w-20 bg-gradient-to-r from-white to-transparent z-10 pointer-events-none"></div>
    <div class="absolute inset-y-0 right-0 w-12 sm:w-20 bg-gradient-to-l from-white to-transparent z-10 pointer-events-none"></div>

    <div class="marquee-track items-center">
      {[...logos, ...logos].map((logo, i) => (
        <div class="inline-flex items-center justify-center mx-6 sm:mx-8 shrink-0 w-[120px] sm:w-[140px] h-[56px]">
          <img
            src={logo.src}
            alt={logo.alt}
            class="max-h-[56px] max-w-[130px] w-auto object-contain grayscale hover:grayscale-0 transition-all duration-300 opacity-70 hover:opacity-100"
          />
        </div>
      ))}
    </div>
  </div>
</section>
