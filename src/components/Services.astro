---
const services = [
  {
    title: 'Solar 3D Pre-Design',
    desc: 'Solar Pre-Design, also known as Solar Preliminary Design, is the first phase in planning a solar project. It involves creating initial layouts and energy estimates.',
    href: '/solar-3d-pre-design/',
    img: '/images/services/service-1.webp',
  },
  {
    title: 'MW Scale Detailed Engineering Design',
    desc: 'Heaven Designs Pvt. Ltd. offers comprehensive MW-scale detailed engineering design, providing a full set of drawings and documentation.',
    href: '/solar-rooftop-detailed-engineering-design/',
    img: '/images/services/service-2.webp',
  },
  {
    title: 'MW Scale Project Management Consultancy',
    desc: 'Heaven Designs Pvt. Ltd. offers exceptional Project Management Consultancy (PMC) services for MW-scale solar projects.',
    href: '/mw-scale-project-management-consultancy/',
    img: '/images/services/service-3.webp',
  },
  {
    title: 'Solar Civil And Structural Engineering',
    desc: 'Heaven Designs Pvt. Ltd. offers comprehensive Civil and Structural Engineering services tailored for solar projects.',
    href: '/solar-civil-and-structural-engineering-3/',
    img: '/images/services/service-4.webp',
  },
  {
    title: 'Site Survey & Feasibility',
    desc: 'Heaven Designs Pvt. Ltd. provides comprehensive Site Survey and Land Feasibility services across various regions.',
    href: '/site-survey-land-feasibility-services/',
    img: '/images/services/service-5.webp',
  },
  {
    title: 'Solar Permit Design',
    desc: 'We make sure that our permit designs are up to the commitments and deliver as per the commitments.',
    href: '/solar-permit-design/',
    img: '/images/services/service-6.webp',
  },
];
---

<section class="py-14 sm:py-20 bg-gray-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10 sm:mb-12">
      <p class="section-label">Services</p>
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-[#1a1a1a]" style="font-family:'Montserrat',sans-serif">
        Our Services
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 sm:gap-6">
      {services.map((s) => (
        <div class="bg-white rounded-lg border border-gray-100 overflow-hidden hover:shadow-lg transition-all duration-300 group flex flex-col">
          <!-- Image area -->
          <div class="h-44 overflow-hidden">
            <img src={s.img} alt={s.title} class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
          </div>
          <!-- Content -->
          <div class="p-6 flex flex-col flex-1">
            <h3 class="text-base sm:text-lg font-bold text-[#1a1a1a] mb-3 leading-snug" style="font-family:'Montserrat',sans-serif">
              {s.title}
            </h3>
            <p class="text-sm sm:text-base text-[#334155] leading-relaxed flex-1">{s.desc}</p>
            <div class="mt-4">
              <a href={s.href} class="read-more">
                Read More
                <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
