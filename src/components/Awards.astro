---
const awards = [
  {
    title: 'Gujarat State Annual Solar Award',
    body: 'We proudly received the Gujarat State Annual Solar Award from EQ Magazine, recognising our outstanding contributions and achievements in the solar energy sector.',
    tag: 'EQ Magazine',
    img: '/images/awards/award-1.webp',
  },
  {
    title: 'Rising Star of the Year 2023',
    body: 'Heaven Designs was honored with the Rising Star of the Year Award 2023 by Progress Alliance for our innovative contributions and excellence in the renewable energy sector.',
    tag: 'Progress Alliance',
    img: '/images/awards/award-2.jpg',
  },
  {
    title: 'State Leadership Award Gujarat',
    body: 'Heaven Designs has been honored with the prestigious State Leadership Award for Solar EPC Company in Gujarat 2024, celebrating our exceptional leadership and impact.',
    tag: 'Gujarat 2024',
    img: '/images/awards/award-3.webp',
  },
  {
    title: 'Young Achiever Award',
    body: 'Keyur Rakholiya, Founder of Heaven Designs, was honored with the Young Achiever Award by his alma mater DDU for his remarkable contributions to renewable energy.',
    tag: 'Founder Award',
    img: '/images/awards/award-4.webp',
  },
];
---

<section class="py-20 bg-white border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-12">
      <p class="section-label">Awards and Recognition</p>
      <h2 class="text-3xl sm:text-4xl font-black text-[#1a1a1a]" style="font-family:'Montserrat',sans-serif">
        Our Achievements
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {awards.map((award) => (
        <div class="border border-gray-100 rounded-lg overflow-hidden hover:shadow-md transition-shadow duration-300 group">
          <!-- Real award photo -->
          <div class="h-52 overflow-hidden">
            <img
              src={award.img}
              alt={award.title}
              class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
            />
          </div>
          <div class="p-5">
            <span class="inline-block bg-[#FFA91F]/15 text-[#FFA91F] text-[10px] font-bold px-2 py-0.5 rounded uppercase tracking-wider mb-2">{award.tag}</span>
            <h3 class="font-bold text-[#149C68] text-lg leading-snug mb-2" style="font-family:'Montserrat',sans-serif">
              {award.title}
            </h3>
            <p class="text-[#334155] text-lg leading-relaxed">{award.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
