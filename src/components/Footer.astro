---
const services = [
  { label: 'Solar 3D Pre-Design', href: '/solar-3d-pre-design/' },
  { label: 'Solar Post-Design', href: '/solar-post-design/' },
  { label: 'Rooftop Engineering Design', href: '/solar-rooftop-detailed-engineering-design/' },
  { label: 'Ground Mount Design', href: '/solar-ground-mount-design/' },
  { label: 'Project Management', href: '/mw-scale-project-management-consultancy/' },
  { label: 'Solar Permit Design', href: '/solar-permit-design/' },
  { label: 'Civil & Structural Engineering', href: '/solar-civil-and-structural-engineering-3/' },
  { label: 'Site Survey & Feasibility', href: '/site-survey-land-feasibility-services/' },
  { label: 'Reports', href: '/reports/' },
];

const quickLinks = [
  { label: 'Home', href: '/' },
  { label: 'About Us', href: '/about-us/' },
  { label: 'Our Culture', href: '/our-culture/' },
  { label: 'Our Projects', href: '/our-projects/' },
  { label: 'Resource Center', href: '/resource-center/' },
  { label: 'Contact Us', href: '/contact-us/' },
  { label: 'Join Our Team', href: '/join-our-team/' },
  { label: 'FAQs', href: '/faqs/' },
  { label: 'Blog', href: '/our-blog/' },
];
---

<footer class="bg-[#149C68] text-white/85">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 pt-14 pb-8">
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-10 mb-10">

      <!-- Brand -->
      <div>
        <!-- Logo -->
        <div class="mb-5">
          <img src="/images/logo.webp" alt="Heaven Designs" class="h-14 w-auto object-contain rounded" />
        </div>

        <p class="text-lg leading-relaxed mb-5 text-white/75">
          Heaven Designs Private Limited — One stop solution for Solar Design, Engineering &amp; Consultancy. Serving EPC companies globally.
        </p>

        <div class="text-lg space-y-2 text-white/75">
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4 text-[#FFA91F] shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"/>
            </svg>
            8AM – 6PM, Mon – Sun
          </div>
          <a href="tel:+919081100297" class="flex items-center gap-2 hover:text-[#FFA91F] transition-colors">
            <svg class="w-4 h-4 text-[#FFA91F] shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
            </svg>
            +91 90811 00297
          </a>
          <a href="mailto:service@heavendesigns.in" class="flex items-center gap-2 hover:text-[#FFA91F] transition-colors">
            <svg class="w-4 h-4 text-[#FFA91F] shrink-0" fill="currentColor" viewBox="0 0 20 20">
              <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
              <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
            </svg>
            service@heavendesigns.in
          </a>
        </div>

        <!-- Social -->
        <div class="flex gap-2 mt-5">
          {[
            { label: 'Facebook', href: 'https://www.facebook.com/', d: 'M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z' },
            { label: 'Twitter', href: 'https://twitter.com/', d: 'M23 3a10.9 10.9 0 01-3.14 1.53 4.48 4.48 0 00-7.86 3v1A10.66 10.66 0 013 4s-4 9 5 13a11.64 11.64 0 01-7 2c9 5 20 0 20-11.5a4.5 4.5 0 00-.08-.83A7.72 7.72 0 0023 3z' },
            { label: 'LinkedIn', href: 'https://www.linkedin.com/', d: 'M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6zM2 9h4v12H2z M4 6a2 2 0 100-4 2 2 0 000 4z' },
            { label: 'YouTube', href: 'https://www.youtube.com/', d: 'M22.54 6.42a2.78 2.78 0 00-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 00-1.95 1.96A29 29 0 001 12a29 29 0 00.46 5.58A2.78 2.78 0 003.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 001.95-1.95A29 29 0 0023 12a29 29 0 00-.46-5.58zM10 15V9l5.25 3z' },
          ].map((s) => (
            <a href={s.href} aria-label={s.label} target="_blank" rel="noopener"
              class="w-8 h-8 rounded bg-white/10 hover:bg-[#FFA91F] flex items-center justify-center transition-colors duration-200">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d={s.d}/>
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Services -->
      <div>
        <h4 class="text-white font-bold mb-5 text-sm uppercase tracking-wider" style="font-family:'Montserrat',sans-serif">Our Services</h4>
        <ul class="space-y-2.5">
          {services.map((s) => (
            <li>
              <a href={s.href} class="text-sm text-white/75 hover:text-[#FFA91F] transition-colors flex items-center gap-1.5">
                <span class="w-1 h-1 rounded-full bg-[#FFA91F] shrink-0"></span>
                {s.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="text-white font-bold mb-5 text-sm uppercase tracking-wider" style="font-family:'Montserrat',sans-serif">Quick Links</h4>
        <ul class="space-y-2.5">
          {quickLinks.map((l) => (
            <li>
              <a href={l.href} class="text-sm text-white/75 hover:text-[#FFA91F] transition-colors flex items-center gap-1.5">
                <span class="w-1 h-1 rounded-full bg-[#FFA91F] shrink-0"></span>
                {l.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Locations -->
      <div>
        <h4 class="text-white font-bold mb-5 text-sm uppercase tracking-wider" style="font-family:'Montserrat',sans-serif">Our Offices</h4>
        <div class="space-y-5">
          <div>
            <p class="text-[#FFA91F] text-xs font-semibold uppercase tracking-wider mb-1.5" style="font-family:'Montserrat',sans-serif">Surat</p>
            <p class="text-lg text-white/75 leading-relaxed">204 Anupam Square, Mota Varachha, Surat, Gujarat, India</p>
          </div>
          <div>
            <p class="text-[#FFA91F] text-xs font-semibold uppercase tracking-wider mb-1.5" style="font-family:'Montserrat',sans-serif">Ahmedabad</p>
            <p class="text-lg text-white/75 leading-relaxed">B1-404 Palladium, Corporate Road, Ahmedabad, Gujarat, India</p>
          </div>
          <div class="pt-2">
            <a href="https://app.heavendesigns.in/register" class="btn-register text-xs px-4 py-2 inline-block">Register Now</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-white/60">
      <p>© {new Date().getFullYear()} Heaven Designs Private Limited. All rights reserved.</p>
      <div class="flex gap-4">
        <a href="/privacy-policy/" class="hover:text-[#FFA91F] transition-colors">Privacy Policy</a>
        <a href="/terms-and-condition/" class="hover:text-[#FFA91F] transition-colors">Terms &amp; Conditions</a>
      </div>
    </div>
  </div>
</footer>
