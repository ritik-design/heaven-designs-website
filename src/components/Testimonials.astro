---
const testimonials = [
  {
    name: 'Mr. Dhaval Savani',
    company: 'Apollo Solar',
    quote: 'We have been working with Heaven Designs for our MW scale solar projects, and they have consistently delivered top-notch designs. Over the course of our partnership, they have successfully completed over 50 MW of projects for us. Their expertise, reliability, and dedication have made them a trusted partner for Apollo Solar. We are extremely satisfied with their service and look forward to continuing our collaboration.',
    avatar: '/images/testi-avatar-1.webp',
  },
  {
    name: 'Mr. Rahul Mehta',
    company: 'Enerture Solar',
    quote: 'Heaven Designs has been an exceptional partner for our EPC projects. Their turnaround time and design accuracy are unmatched. We have completed multiple projects with zero design rework. Highly recommended for any solar EPC company looking for reliable design support.',
    avatar: '/images/testi-avatar-2.webp',
  },
  {
    name: 'Mr. Suresh Patel',
    company: 'Bhageria Industries',
    quote: 'Their team understood our complex requirements quickly and delivered designs that exceeded our expectations. The structural engineering support was particularly impressive. We look forward to a long-term partnership with Heaven Designs.',
    avatar: '/images/testi-avatar-3.webp',
  },
];

let current = 0;
---

<section class="py-14 sm:py-20 bg-white border-t border-gray-100">
  <div class="max-w-4xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-10 sm:mb-12">
      <h2 class="text-2xl sm:text-3xl md:text-4xl font-black text-[#1a1a1a]" style="font-family:'Montserrat',sans-serif">
        Testimonials
      </h2>
    </div>

    <!-- Carousel -->
    <div class="relative" id="testimonial-carousel">
      {testimonials.map((t, i) => (
        <div
          class={`testimonial-slide text-center px-2 sm:px-12 ${i === 0 ? '' : 'hidden'}`}
          data-idx={i}
        >
          <!-- Avatar -->
          <div class="w-16 h-16 sm:w-20 sm:h-20 rounded-full overflow-hidden mx-auto mb-5 sm:mb-6 border-4 border-[#149C68]/20">
            <img src={t.avatar} alt={t.name} class="w-full h-full object-cover" />
          </div>

          <p class="font-bold text-[#149C68] mb-0.5 text-base sm:text-lg" style="font-family:'Montserrat',sans-serif">{t.name}</p>
          <p class="text-sm sm:text-base text-[#334155] mb-5 sm:mb-6">{t.company}</p>

          <blockquote class="text-[#334155] leading-relaxed text-sm sm:text-base md:text-lg italic border-l-4 border-[#149C68]/30 pl-4 sm:pl-6 text-left">
            "{t.quote}"
          </blockquote>
        </div>
      ))}
    </div>

    <!-- Dots -->
    <div class="flex justify-center gap-2 mt-8">
      {testimonials.map((_, i) => (
        <button
          class={`testimonial-dot w-3 h-3 rounded-full transition-colors ${i === 0 ? 'bg-[#149C68]' : 'bg-gray-200'}`}
          data-to={i}
          aria-label={`Go to testimonial ${i + 1}`}
        ></button>
      ))}
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.testimonial-slide');
  const dots = document.querySelectorAll('.testimonial-dot');

  function goTo(idx: number) {
    slides.forEach((s, i) => s.classList.toggle('hidden', i !== idx));
    dots.forEach((d, i) => {
      (d as HTMLElement).style.backgroundColor = i === idx ? '#149C68' : '#e5e7eb';
    });
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      const idx = parseInt((dot as HTMLElement).dataset.to || '0');
      goTo(idx);
    });
  });

  // Auto-rotate
  let current = 0;
  setInterval(() => {
    current = (current + 1) % slides.length;
    goTo(current);
  }, 5000);
</script>
