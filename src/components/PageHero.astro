---
interface Props {
  title: string;
  subtitle?: string;
  breadcrumbs?: { label: string; href?: string }[];
}
const { title, subtitle, breadcrumbs = [] } = Astro.props;
---

<section class="relative bg-[#149C68] pt-[70px]">
  <!-- Subtle pattern overlay -->
  <div class="absolute inset-0 opacity-10">
    <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="pg-dots" width="30" height="30" patternUnits="userSpaceOnUse">
          <circle cx="15" cy="15" r="1.5" fill="white"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#pg-dots)"/>
    </svg>
  </div>
  <!-- Diagonal white cut -->
  <div class="absolute bottom-0 left-0 right-0 overflow-hidden leading-none">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-10 sm:h-14">
      <polygon points="0,60 1440,0 1440,60" fill="white"/>
    </svg>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 py-16 pb-20">
    <!-- Breadcrumbs -->
    {breadcrumbs.length > 0 && (
      <nav aria-label="Breadcrumb" class="mb-4">
        <ol class="flex flex-wrap items-center gap-2 text-sm text-white/70" itemscope itemtype="https://schema.org/BreadcrumbList">
          <li itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
            <a href="/" itemprop="item" class="hover:text-white transition-colors">
              <span itemprop="name">Home</span>
            </a>
            <meta itemprop="position" content="1" />
          </li>
          {breadcrumbs.map((crumb, i) => (
            <li class="flex items-center gap-2" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
              <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
              {crumb.href ? (
                <a href={crumb.href} itemprop="item" class="hover:text-white transition-colors">
                  <span itemprop="name">{crumb.label}</span>
                </a>
              ) : (
                <span class="text-white font-medium" itemprop="name">{crumb.label}</span>
              )}
              <meta itemprop="position" content={String(i + 2)} />
            </li>
          ))}
        </ol>
      </nav>
    )}

    <h1 class="text-3xl sm:text-4xl lg:text-5xl font-black text-white leading-tight" style="font-family:'Montserrat',sans-serif">
      {title}
    </h1>
    {subtitle && (
      <p class="mt-3 text-white/80 text-lg max-w-2xl leading-relaxed">{subtitle}</p>
    )}
  </div>
</section>
