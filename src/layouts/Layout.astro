---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  type?: 'website' | 'article';
  noindex?: boolean;
  schema?: object;
}

const {
  title = 'Heaven Designs – Solar Design, Engineering & Consultancy',
  description = 'Heaven Designs Pvt. Ltd. is a one-stop solution for Solar Design, Engineering & Consultancy. Serving 300+ EPC companies globally with 50+ expert engineers from Surat, Gujarat.',
  canonical = Astro.url.href,
  ogImage = '/images/hero-bg.jpg',
  type = 'website',
  noindex = false,
  schema,
} = Astro.props;

const siteName = 'Heaven Designs';
const siteUrl = 'https://heavendesigns.in';

// Default org schema injected on every page
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Heaven Designs Private Limited',
  url: siteUrl,
  logo: `${siteUrl}/images/logo.webp`,
  description: 'Solar design, engineering and consultancy company based in Surat, Gujarat, India.',
  telephone: '+91-90811-00297',
  email: 'service@heavendesigns.in',
  address: [
    {
      '@type': 'PostalAddress',
      streetAddress: '204 Anupam Square, Mota Varachha',
      addressLocality: 'Surat',
      addressRegion: 'Gujarat',
      addressCountry: 'IN',
    },
    {
      '@type': 'PostalAddress',
      streetAddress: 'B1-404 Palladium, Corporate Road',
      addressLocality: 'Ahmedabad',
      addressRegion: 'Gujarat',
      addressCountry: 'IN',
    },
  ],
  sameAs: [
    'https://www.facebook.com/',
    'https://www.linkedin.com/',
    'https://twitter.com/',
    'https://www.youtube.com/',
  ],
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: ['Monday','Tuesday','Wednesday','Thursday','Friday','Saturday','Sunday'],
    opens: '08:00',
    closes: '18:00',
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex,nofollow" />}

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:image" content={`${siteUrl}${ogImage}`} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${siteUrl}${ogImage}`} />

    <!-- Geo -->
    <meta name="geo.region" content="IN-GJ" />
    <meta name="geo.placename" content="Surat, Gujarat, India" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800;900&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <!-- Schema.org: Organization (every page) -->
    <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />
    <!-- Schema.org: Page-specific -->
    {schema && <script type="application/ld+json" set:html={JSON.stringify(schema)} />}
  </head>
  <body class="bg-white">
    <slot />
  </body>
</html>
